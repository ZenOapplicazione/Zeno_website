---
// Sticky CTA bar: appears after scrolling past the hero, stays visible during scroll,
// hides near the footer, dismissible per session.
---

<aside id="stickyCta" class="sticky-cta" aria-hidden="true">
  <div class="sc-inner">
    <a href="/questionario-utenti" class="sc-pill sc-pill-light">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Sei un consumatore?</span>
    </a>
    <a href="/questionario-produttori" class="sc-pill sc-pill-dark">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Sei un produttore?</span>
    </a>
    <button type="button" id="stickyCtaClose" class="sc-close" aria-label="Chiudi">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</aside>

<style>
  .sticky-cta {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    z-index: 50;
    transform: translateX(-50%) translateY(160%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s ease;
  }
  .sticky-cta.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .sc-inner {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    background: #ffffff;
    padding: 0.4rem 0.5rem 0.4rem 0.4rem;
    border-radius: 99px;
    box-shadow: 0 14px 40px rgba(20, 50, 35, 0.18), 0 4px 12px rgba(0, 0, 0, 0.06);
  }

  .sc-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.05rem;
    border-radius: 99px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }
  .sc-pill svg { width: 16px; height: 16px; flex-shrink: 0; }
  .sc-pill:hover { transform: translateY(-1px); }
  .sc-pill-light { background: #407d54; }
  .sc-pill-light:hover { background: #2d5d3d; }
  .sc-pill-dark { background: #1c4233; }
  .sc-pill-dark:hover { background: #132f24; }

  .sc-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    margin-left: 0.1rem;
    background: transparent;
    color: #6b7280;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .sc-close svg { width: 18px; height: 18px; }
  .sc-close:hover { background: #f3f4f6; color: #111827; }

  @media (max-width: 640px) {
    .sticky-cta {
      left: 0;
      right: 0;
      bottom: 0;
      transform: translateY(110%);
    }
    .sticky-cta.visible {
      transform: translateY(0);
    }
    .sc-inner {
      gap: 0.5rem;
      padding: 0.65rem 0.75rem calc(0.65rem + env(safe-area-inset-bottom)) 0.75rem;
      border-radius: 0;
      border-top: 1px solid #e5e7eb;
      box-shadow: 0 -8px 24px rgba(20, 50, 35, 0.08);
    }
    .sc-pill {
      flex: 1 1 0;
      min-width: 0;
      justify-content: center;
      padding: 0.65rem 0.5rem;
      font-size: 0.8rem;
    }
    .sc-pill span {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sc-close {
      width: 28px;
      height: 28px;
      flex-shrink: 0;
    }
    .sc-close svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<script>
  (function () {
    const bar = document.getElementById('stickyCta');
    const closeBtn = document.getElementById('stickyCtaClose');
    if (!bar || !closeBtn) return;

    const KEY = 'zenoStickyCtaDismissed';
    if (sessionStorage.getItem(KEY) === '1') return;

    const SHOW_AFTER = 500;
    const FOOTER_BUFFER = 80;
    const footer = document.querySelector('footer');

    function update() {
      const scrolled = window.scrollY;
      const winBottom = window.innerHeight + scrolled;

      const pastShowThreshold = scrolled > SHOW_AFTER;
      let nearFooter = false;

      if (footer) {
        const footerTop = footer.getBoundingClientRect().top + scrolled;
        nearFooter = winBottom > footerTop - FOOTER_BUFFER;
      }

      if (pastShowThreshold && !nearFooter) {
        bar.classList.add('visible');
        bar.setAttribute('aria-hidden', 'false');
      } else {
        bar.classList.remove('visible');
        bar.setAttribute('aria-hidden', 'true');
      }
    }

    closeBtn.addEventListener('click', () => {
      bar.classList.remove('visible');
      bar.setAttribute('aria-hidden', 'true');
      sessionStorage.setItem(KEY, '1');
      window.removeEventListener('scroll', update);
      window.removeEventListener('resize', update);
    });

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  })();
</script>
