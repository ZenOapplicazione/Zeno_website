---
import { getFooter } from '../lib/strapi';
const footer = await getFooter();
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">

      <div class="footer-col-left">
        <div class="footer-left-title">{footer.logo}</div>
        <p class="footer-tagline">{footer.tagline}</p>

        <div class="footer-email-label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {footer.emailLabel}
        </div>
        <form class="footer-email-row" id="hero-email-footer" data-formspree={footer.formspreeUrl}>
          <input type="email" name="email" id="hero-email-input-footer" placeholder={footer.emailPlaceholder} required>
          <button type="submit" id="hero-email-btn-footer">{footer.emailButtonText}</button>
        </form>
        <script>
      document.getElementById('hero-email-footer').addEventListener('submit', async function(e) {
        e.preventDefault();
        const form = e.target;
        const input = document.getElementById('hero-email-input-footer');
        const btn = document.getElementById('hero-email-btn-footer');
        const data = new FormData(form);
        const formspreeUrl = form.getAttribute('data-formspree');

        try {
          const res = await fetch(formspreeUrl, {
            method: 'POST',
            body: data,
            headers: { 'Accept': 'application/json' }
          });
          console.log(res)
          if (res.ok) {
            input.value = 'Grazie, sarai aggiornato presto! 🌱';
            input.readOnly = true;
            input.style.background = '#e8f0e3';
            input.style.color = '#2e3a28';
            input.style.fontWeight = '500';
            btn.disabled = true;
            btn.style.opacity = '0.4';
            btn.style.cursor = 'default';
          }
        } catch(err) {
          console.error(err);
        }
      });
    </script>
      </div>



      <div class="footer-col-right">
        <div class="footer-right-title">{footer.contributeTitle}</div>
        <div class="footer-cards">

          {footer.contributeCards.map((card, i) => (
            <a href={card.url} class={`footer-card ${i === footer.contributeCards.length - 1 && footer.contributeCards.length > 2 ? 'full' : ''}`}>
              <div class="footer-card-icon">
                <Fragment set:html={card.icon} />
              </div>
              <h4>{card.title}</h4>
              <p>{card.description}</p>
            </a>
          ))}

        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; {footer.copyright.replace('{year}', String(currentYear))}</span>

      <button class="footer-back-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
        Torna su
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--forest);
    color: var(--white);
    padding: 5rem 4rem 2.5rem;
    font-family: var(--font-body, system-ui, sans-serif);
  }

  .footer-inner { max-width: 1100px; margin: clamp(2rem, 4vw, 4rem) auto; }
  .footer-top { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; margin-bottom: 4rem; }
  .footer-left-title { font-family: var(--font-display); font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 900; color: rgb(255,255,255); line-height: 0.95; margin-bottom: 1rem; margin-top: 4rem;}
  .footer-tagline { font-size: 0.95rem; color: rgba(255,255,255,0.65); margin-bottom: 2rem; }

  .footer-email-label { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 600; color: rgb(255,255,255); margin-bottom: 0.7rem; }
  .footer-email-label svg { width: 16px; height: 16px; stroke: currentColor; }
  .footer-email-row { display: flex; gap: 0.5rem; }
  .footer-email-row input { flex: 1; padding: 0.8rem 1rem; background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.2); border-radius: 8px; color: var(--white); font-family: inherit; font-size: 0.9rem; outline: none; transition: border-color .2s; }
  .footer-email-row input::placeholder { color: rgba(255,255,255,0.4); }
  .footer-email-row input:focus { border-color: rgba(255,255,255,0.5); }
  .footer-email-row button { padding: 0.8rem 1.4rem; background: #6A8F5A; color: rgb(255,255,255); border: none; border-radius: 8px; font-family: inherit; font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: background .2s; white-space: nowrap; }
  .footer-email-row button:hover { background: var(--forest-light); }

  .footer-right-title { font-size: 1.3rem; font-weight: 600; color: rgb(255,255,255); margin-bottom: 1.2rem; }
  .footer-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  .footer-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 1.4rem 1.3rem; cursor: pointer; transition: background .2s, transform .15s; text-decoration: none; display: block; }
  .footer-card:hover { background: rgba(255,255,255,0.12); transform: translateY(-2px); }
  .footer-card.full { grid-column: 1 / -1; }
  .footer-card-icon { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.8rem; color: var(--sage-light); }
  .footer-card-icon svg { width: 22px; height: 22px; stroke: currentColor; }
  .footer-card h4 { font-size: 0.95rem; font-weight: 600; color: rgb(255,255,255); margin-bottom: 0.4rem; line-height: 1.3; }
  .footer-card p { font-size: 0.78rem; color: rgba(255,255,255,0.5); line-height: 1.5; margin: 0; }

  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; }
  .footer-copy { font-size: 0.78rem; color: rgba(255,255,255,0.4); }

  .footer-back-top { background: transparent; border: none; font-size: 0.78rem; color: rgba(255,255,255,0.6); cursor: pointer; display: flex; align-items: center; gap: 0.4rem; transition: color .2s; padding: 0; font-family: inherit;}
  .footer-back-top:hover { color: rgb(255,255,255); }
  .footer-back-top svg { width: 14px; height: 14px; stroke: currentColor; }

  /* Responsive Mobile */
  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
    .footer-cards { grid-template-columns: 1fr; }
    .footer-card.full { grid-column: 1; }
    footer { padding: 2.5rem 1rem 1.5rem; }
    .footer-left-title { font-size: clamp(2rem, 7vw, 3rem); margin-top: 1.5rem; }
    .footer-card { padding: 1rem; border-radius: 10px; }
    .footer-card h4 { font-size: 0.88rem; }
    .footer-right-title { font-size: 1.1rem; }
  }
  @media (max-width: 540px) {
    .footer-email-row { flex-direction: column; }
  }
</style>
