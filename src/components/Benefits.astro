---
import { getBenefits } from '../lib/strapi';
import { fetchSvgInline } from '../lib/svg';
import type { BenefitsData } from '../lib/types';
interface Props { data?: BenefitsData; }
const benefits = Astro.props.data ?? await getBenefits();
const rowSvgs = await Promise.all(benefits.rows.map(r => fetchSvgInline(r.icon?.url)));
---
<style>
  .section-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    font-family: var(--font-display, inherit);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }
  .benefits-section { background: rgb(237, 233, 222); padding: clamp(2.5rem, 5vw, 4rem) clamp(1rem, 3vw, 2rem) clamp(3rem, 5vw, 6rem); }
  .benefits-inner { max-width: 100rem; margin: 0 auto; }
  .benefits-header { text-align: center; margin-bottom: clamp(2rem, 4vw, 4rem); }

  /* ── ROW LAYOUT ── */
  .benefits-rows { display: flex; flex-direction: column; gap: 2rem; }

  .brow {
    display: flex;
    gap: 2rem;
    align-items: stretch;
  }

  /* Alternating: odd rows → image left; even rows → image right */
  .brow.img-right { flex-direction: row-reverse; }

  /* Image cell */
  .bcard-image {
    flex: 1;
    border-radius: 20px;
    overflow: hidden;
    background: #e8f0e3;
    align-self: stretch;
    position: relative;
  }
  .bcard-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Card cell */
  .bcard {
    flex: 1;
    background: rgb(255,255,255);
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid var(--border-card);
    box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    display: flex;
    flex-direction: column;
  }

  .bcard-icon {
    background: rgb(101,155,94,0.30);
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .bcard-icon :global(svg) { width: 20px; height: 20px; stroke: #2e3a28; stroke-width: 1.5; }

  .bcard h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .bcard p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .bcard-change {
    background: var(--cream);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    margin-top: auto;
  }
  .bcard-change-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 0.8rem;
  }
  .bcard-change ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .bcard-change li {
    font-size: 0.9rem;
    color: var(--text-dark);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .bcard-change li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #9ca883;
    flex-shrink: 0;
  }

  .impact-caption {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    max-width: 700px;
    margin: 0.8rem auto 0;
    color: #1f2937;
  }
  .impact-caption strong { font-weight: 700; }

  .benefits-cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .benefits-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--forest-btn, #3e7c59);
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 99px;
    background: rgba(62, 124, 89, 0.08);
    border: 1px solid rgba(62, 124, 89, 0.2);
    transition: background 0.2s, transform 0.15s;
  }

  .benefits-cta-link:hover {
    background: rgba(62, 124, 89, 0.15);
    transform: translateY(-1px);
  }

  .benefits-cta-link svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .section-cta-wrap { text-align: center; margin-top: clamp(2rem, 4vw, 3rem); }
  .section-cta-text {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--forest-btn, #3e7c59);
    text-decoration: none;
    padding: 0.65rem 1.4rem;
    border-radius: 99px;
    background: rgba(62, 124, 89, 0.08);
    border: 1px solid rgba(62, 124, 89, 0.2);
    transition: background 0.2s, transform 0.15s;
  }
  .section-cta-text:hover { background: rgba(62, 124, 89, 0.15); transform: translateY(-1px); }

  @media (max-width: 768px) {
    .brow,
    .brow.img-right { flex-direction: column; }
    .bcard-image { min-height: 180px; }
    .bcard { padding: 1.2rem; border-radius: 14px; }
    .bcard h3 { font-size: 1.1rem; }
    .bcard p { font-size: 0.88rem; }
  }
</style>

<section class="benefits-section">
  <div class="benefits-inner">
    <div class="benefits-header fade-up">
      <h2 class="section-title">{benefits.title}</h2>
      <p class="impact-caption" set:html={benefits.caption} />
      <div class="benefits-cta-row">
        <a href="/questionario-utenti" class="benefits-cta-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          Questionario consumatori
        </a>
        <a href="/questionario-produttori" class="benefits-cta-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Questionario produttori
        </a>
      </div>
    </div>

    <div class="benefits-rows">

      {benefits.rows.map((row, i) => (
        <div class={`brow fade-up ${i % 2 !== 0 ? 'img-right' : ''}`}>
          <div class="bcard-image">
            <img src={row.image.url} alt={row.image.alternativeText || row.title} />
          </div>
          <div class="bcard">
            <div class="bcard-icon">
              <Fragment set:html={rowSvgs[i]} />
            </div>
            <h3>{row.title}</h3>
            <p>{row.description}</p>
            <div class="bcard-change">
              <div class="bcard-change-title">Cosa cambia</div>
              <ul>
                {row.changes.map((change) => (
                  <li>{change.text}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}

    </div>

  </div>
</section>