---
// src/components/HowItWorks.astro
---
<style>
  .how-section {
    background-color: #233f2d;
    color: #ffffff;
    font-family: var(--font-body, system-ui, sans-serif);
    padding: clamp(2.5rem, 5vw, 5rem) 0 clamp(2rem, 4vw, 4rem);
    margin-top: -1px;
  }

  .how-header {
    text-align: center;
    padding: 0 2rem;
    margin-bottom: clamp(1rem, 3vw, 2.5rem);
  }

  .section-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(1.8rem, 3.5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .section-sub {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 700px;
    margin: 0.8rem auto 0;
    line-height: 1.5;
  }

  .how-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .how-grid {
    display: flex;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 4vw, 4.5rem) clamp(2rem, 3vw, 3.5rem);
    transition: transform 0.4s ease;
  }
  .how-grid::after {
    content: '';
    flex-shrink: 0;
    width: clamp(1rem, 4vw, 4.5rem);
    min-height: 1px;
  }

  /* Card */
  .how-card {
    background: #ffffff;
    border-radius: 16px;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.2rem, 2.5vw, 2rem);
    text-align: left;
    position: relative;
    width: clamp(260px, 75vw, 320px);
    flex-shrink: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .how-badge {
    position: absolute;
    top: clamp(-14px, -2vw, -22px);
    left: clamp(-14px, -2vw, -22px);
    width: clamp(32px, 5vw, 44px);
    height: clamp(32px, 5vw, 44px);
    background: #51852a;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.85rem, 1.5vw, 1.15rem);
    font-weight: 400;
  }

  .how-icon-box {
    width: 60px;
    height: 60px;
    background: #cceae0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .how-icon-box svg {
    width: 28px;
    height: 28px;
    color: #233f2d;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-card h3 {
    font-size: 1.2rem;
    font-weight: 500;
    color: #111827;
    margin-bottom: 0.8rem;
    line-height: 1.3;
  }
  .how-card p {
    font-size: 0.98rem;
    color: #4b5563;
    line-height: 1.6;
  }

  /* Footer: arrows + dots */
  .how-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 2rem;
  }

  .how-arrows {
    display: flex;
    gap: 0.75rem;
  }
  .how-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    background: transparent;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  }
  .how-arrow:hover:not(:disabled) {
    background: rgba(255,255,255,0.15);
    border-color: white;
  }
  .how-arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .how-arrow svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-progress {
    display: flex;
    gap: 7px;
    align-items: center;
  }
  .how-progress-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    transition: background 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .how-progress-dot.active {
    background: #ffffff;
    transform: scale(1.4);
  }

  /* When all cards fit — hide controls, center cards */
  .how-section.no-carousel .how-grid {
    justify-content: center;
    flex-wrap: wrap;
    padding: 2.5rem 2rem 3rem;
  }
  .how-section.no-carousel .how-card {
    width: clamp(260px, 18vw, 320px);
  }
  .how-section.no-carousel .how-footer {
    display: none;
  }
  .how-section.no-carousel .how-grid::after {
    display: none;
  }
</style>

<section class="how-section" id="howSection">
  <div class="how-header">
    <h2 class="section-title fade-up">Organizza la tua spesa etica<br>in 3 minuti</h2>
    <p class="section-sub fade-up">
      ZenO connette persone, produttori e punti di ritiro in un unico flusso condiviso.
      Gli ordini collettivi aumentano il risparmio ambientale e rendono la spesa etica più accessibile.
    </p>
  </div>

  <div class="how-carousel" id="howCarousel">
    <div class="how-grid" id="howGrid">

      <div class="how-card">
        <div class="how-badge">1</div>
        <div class="how-icon-box">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
          </svg>
        </div>
        <h3>Unisciti o crea un gruppo</h3>
        <p>ZenO ti permette di accedere a una rete di acquisto sostenibile. Puoi unirti a un gruppo vicino a te oppure crearne uno nuovo in pochi minuti.</p>
      </div>

      <div class="how-card">
        <div class="how-badge">2</div>
        <div class="how-icon-box">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3>Scopri i produttori locali</h3>
        <p>Ogni gruppo collabora con produttori selezionati in base a qualità, distanza e impatto ambientale.</p>
      </div>

      <div class="how-card">
        <div class="how-badge">3</div>
        <div class="how-icon-box">
          <svg viewBox="0 0 24 24" fill="none">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6"/>
          </svg>
        </div>
        <h3>Ordina insieme agli altri membri</h3>
        <p>Gli ordini sono collettivi: più persone partecipano, maggiore è l'efficienza logistica e il risparmio.</p>
      </div>

      <div class="how-card">
        <div class="how-badge">4</div>
        <div class="how-icon-box">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3>Ritira in un punto condiviso</h3>
        <p>La consegna avviene in un punto di ritiro organizzato dal gruppo.</p>
      </div>

      <div class="how-card">
        <div class="how-badge">5</div>
        <div class="how-icon-box">
          <svg viewBox="0 0 24 24" fill="none">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
        <h3>Monitora il tuo impatto</h3>
        <p>Ogni acquisto genera un report chiaro sul risparmio ambientale raggiunto.</p>
      </div>

    </div>
  </div>

  <div class="how-footer" id="howFooter">
    <button class="how-arrow" id="howPrev" disabled>
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="how-progress" id="howProgress"></div>
    <button class="how-arrow" id="howNext">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
  </div>
</section>

<script>
(function () {
  const section    = document.getElementById('howSection');
  const carousel   = document.getElementById('howCarousel');
  const grid       = document.getElementById('howGrid');
  const progressEl = document.getElementById('howProgress');
  const btnPrev    = document.getElementById('howPrev');
  const btnNext    = document.getElementById('howNext');

  if (!carousel || !grid || !section || !progressEl) return;

  const allCards = Array.from(grid.querySelectorAll('.how-card'));
  let currentPage  = 0;
  let pageCount    = 0;
  let dotEls       = [];

  function getCardWidth() {
    const gap = parseInt(getComputedStyle(grid).gap) || 40;
    return allCards[0] ? allCards[0].offsetWidth + gap : 360;
  }

  function getVisibleCount() {
    return Math.max(1, Math.floor(carousel.clientWidth / getCardWidth()));
  }

  function getMaxX() {
    return Math.max(0, grid.scrollWidth - carousel.clientWidth);
  }

  function buildDots(n) {
    progressEl.innerHTML = '';
    dotEls = [];
    for (let i = 0; i < n; i++) {
      const d = document.createElement('div');
      d.className = 'how-progress-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goToPage(i));
      progressEl.appendChild(d);
      dotEls.push(d);
    }
  }

  function goToPage(page) {
    page = Math.max(0, Math.min(page, pageCount - 1));
    currentPage = page;
    const x = Math.min(page * getVisibleCount() * getCardWidth(), getMaxX());
    grid.style.transform = `translateX(-${x}px)`;
    updateUI();
  }

  function updateUI() {
    dotEls.forEach((d, i) => d.classList.toggle('active', i === currentPage));
    if (btnPrev) btnPrev.disabled = currentPage <= 0;
    if (btnNext) btnNext.disabled = currentPage >= pageCount - 1;
  }

  function setup() {
    // Check if all cards fit by comparing total card width to container
    const cardW = getCardWidth();
    const totalCardsWidth = allCards.length * cardW;
    const fits = totalCardsWidth <= carousel.clientWidth + 10;

    if (fits) {
      section.classList.add('no-carousel');
      grid.style.transform = '';
      buildDots(0);
      return;
    }
    section.classList.remove('no-carousel');
    const visible = getVisibleCount();
    pageCount = Math.ceil(allCards.length / visible);
    buildDots(pageCount);
    goToPage(Math.min(currentPage, pageCount - 1));
  }

  // Touch/swipe support
  let touchStartX = 0;
  let touchDeltaX = 0;
  carousel.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchDeltaX = 0;
  }, { passive: true });
  carousel.addEventListener('touchmove', (e) => {
    touchDeltaX = e.touches[0].clientX - touchStartX;
  }, { passive: true });
  carousel.addEventListener('touchend', () => {
    if (Math.abs(touchDeltaX) > 50) {
      goToPage(currentPage + (touchDeltaX < 0 ? 1 : -1));
    }
  });

  btnPrev?.addEventListener('click', () => goToPage(currentPage - 1));
  btnNext?.addEventListener('click', () => goToPage(currentPage + 1));

  if (document.readyState === 'complete') {
    requestAnimationFrame(setup);
  } else {
    window.addEventListener('load', () => requestAnimationFrame(setup));
  }
  window.addEventListener('resize', setup);
})();
</script>