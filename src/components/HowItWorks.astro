---
// src/components/HowItWorks.astro
---
<style>
  .how-section {
    background-color: #233f2d;
    color: #ffffff;
    font-family: var(--font-body, system-ui, sans-serif);
  }

  .how-scroll-wrapper {
    position: relative;
  }

  .how-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
    overflow: hidden;
  }

  .how-header {
    text-align: center;
    padding: 0 2rem;
    flex-shrink: 0;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(1.8rem, 3.5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .section-sub {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 700px;
    margin: 0.8rem auto 0;
    line-height: 1.5;
  }

  .how-grid-outer {
    width: 100%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .how-grid {
    display: flex;
    gap: 2.5rem;
    padding: 2.5rem 4.5rem 3.5rem;
    width: max-content;
    will-change: transform;
  }

  /* Card */
  .how-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: left;
    position: relative;
    width: 320px;
    flex-shrink: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .how-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .how-badge {
    position: absolute;
    top: -22px;
    left: -22px;
    width: 44px;
    height: 44px;
    background: #51852a;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    font-weight: 400;
  }

  .how-icon-box {
    width: 60px;
    height: 60px;
    background: #cceae0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .how-icon-box svg {
    width: 28px;
    height: 28px;
    color: #233f2d;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-card h3 {
    font-size: 1.2rem;
    font-weight: 500;
    color: #111827;
    margin-bottom: 0.8rem;
    line-height: 1.3;
  }
  .how-card p {
    font-size: 0.98rem;
    color: #4b5563;
    line-height: 1.6;
  }

  /* Footer: frecce + dots */
  .how-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-shrink: 0;
    padding: 0 2rem;
  }

  .how-arrows {
    display: flex;
    gap: 0.75rem;
  }
  .how-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    background: transparent;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  }
  .how-arrow:hover:not(:disabled) {
    background: rgba(255,255,255,0.15);
    border-color: white;
  }
  .how-arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .how-arrow svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-progress {
    display: flex;
    gap: 7px;
    align-items: center;
  }
  /* I dot vengono generati via JS, questo è lo stile base */
  .how-progress-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    transition: background 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .how-progress-dot.active {
    background: #ffffff;
    transform: scale(1.4);
  }

  /* Modalità statica (tutte le card visibili) */
  .how-section.no-scroll .how-scroll-wrapper {
    height: auto !important;
  }
  .how-section.no-scroll .how-sticky {
    position: static;
    height: auto;
    padding: 5rem 0 4rem;
  }
  .how-section.no-scroll .how-grid {
    justify-content: center;
    width: 100%;
    flex-wrap: wrap;
    padding: 2.5rem 2rem 3rem;
  }
  .how-section.no-scroll .how-card {
    width: clamp(260px, 18vw, 320px);
  }
  /* Nascondi footer se non serve scrollare */
  .how-section.no-scroll .how-footer {
    display: none;
  }
</style>

<section class="how-section" id="howSection">
  <div class="how-scroll-wrapper" id="howScrollWrapper">
    <div class="how-sticky" id="howSticky">

      <div class="how-header">
        <h2 class="section-title fade-up">Organizza la tua spesa etica<br>in 3 minuti</h2>
        <p class="section-sub fade-up">
          ZenO connette persone, produttori e punti di ritiro in un unico flusso condiviso.
          Gli ordini collettivi aumentano il risparmio ambientale e rendono la spesa etica più accessibile.
        </p>
      </div>

      <div class="how-grid-outer" id="howGridOuter">
        <div class="how-grid" id="howGrid">

          <div class="how-card">
            <div class="how-badge">1</div>
            <div class="how-icon-box">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
              </svg>
            </div>
            <h3>Unisciti o crea un gruppo</h3>
            <p>ZenO ti permette di accedere a una rete di acquisto sostenibile. Puoi unirti a un gruppo vicino a te oppure crearne uno nuovo in pochi minuti.</p>
          </div>

          <div class="how-card">
            <div class="how-badge">2</div>
            <div class="how-icon-box">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3>Scopri i produttori locali</h3>
            <p>Ogni gruppo collabora con produttori selezionati in base a qualità, distanza e impatto ambientale.</p>
          </div>

          <div class="how-card">
            <div class="how-badge">3</div>
            <div class="how-icon-box">
              <svg viewBox="0 0 24 24" fill="none">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6"/>
              </svg>
            </div>
            <h3>Ordina insieme agli altri membri</h3>
            <p>Gli ordini sono collettivi: più persone partecipano, maggiore è l'efficienza logistica e il risparmio.</p>
          </div>

          <div class="how-card">
            <div class="how-badge">4</div>
            <div class="how-icon-box">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            </div>
            <h3>Ritira in un punto condiviso</h3>
            <p>La consegna avviene in un punto di ritiro organizzato dal gruppo.</p>
          </div>

          <div class="how-card">
            <div class="how-badge">5</div>
            <div class="how-icon-box">
              <svg viewBox="0 0 24 24" fill="none">
                <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
              </svg>
            </div>
            <h3>Monitora il tuo impatto</h3>
            <p>Ogni acquisto genera un report chiaro sul risparmio ambientale raggiunto.</p>
          </div>

        </div>
      </div>

      <!-- Frecce + Dots (i dot vengono generati via JS) -->
      <div class="how-footer" id="howFooter">

        <div class="how-progress" id="howProgress"></div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  const section     = document.getElementById('howSection');
  const wrapper     = document.getElementById('howScrollWrapper');
  const outer       = document.getElementById('howGridOuter');
  const grid        = document.getElementById('howGrid');
  const progressEl  = document.getElementById('howProgress');
  const btnPrev     = document.getElementById('howPrev');
  const btnNext     = document.getElementById('howNext');

  if (!wrapper || !grid || !outer || !section || !progressEl) return;

  const PAUSE_PX   = window.innerHeight * 0.2;
  const allCards   = Array.from(document.querySelectorAll('#howGrid .how-card'));
  let currentX     = 0;
  let isScrollMode = false;
  let dotEls       = [];  // dot generati dinamicamente
  let visibleCount = 0;   // quante card entrano nella viewport
  let pageCount    = 0;   // numero di "pagine" = dot necessari

  /* ── Animazione entrata card ── */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = allCards.indexOf(e.target);
        setTimeout(() => e.target.classList.add('visible'), idx * 100);
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  allCards.forEach(c => io.observe(c));

  /* ── Quante card entrano in schermo ── */
  function getVisibleCount() {
    const gap    = parseInt(getComputedStyle(grid).gap) || 40;
    const cardW  = allCards[0] ? allCards[0].offsetWidth + gap : 360;
    return Math.max(1, Math.floor(outer.clientWidth / cardW));
  }

  /* ── Massimo spostamento ── */
  function getMaxX() {
    return Math.max(0, grid.scrollWidth - outer.clientWidth);
  }

  /* ── Genera i dot in base a quante "pagine" ci sono ──
     Una pagina = uno spostamento di visibleCount card.
     Es: 5 card, 2 visibili → 3 pagine (0-1, 1-2, 2-4) → 3 dot */
  function buildDots(nDots) {
    progressEl.innerHTML = '';
    dotEls = [];
    for (let i = 0; i < nDots; i++) {
      const d = document.createElement('div');
      d.className = 'how-progress-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goToPage(i));
      progressEl.appendChild(d);
      dotEls.push(d);
    }
  }

  /* ── Vai a una pagina specifica ── */
  function goToPage(pageIndex) {
    const gap   = parseInt(getComputedStyle(grid).gap) || 40;
    const cardW = allCards[0] ? allCards[0].offsetWidth + gap : 360;
    applyX(pageIndex * visibleCount * cardW);
  }

  /* ── Setup: calcola tutto e ridisegna dot ── */
  function setup() {
    const maxX = getMaxX();

    if (maxX <= 10) {
      section.classList.add('no-scroll');
      isScrollMode = false;
      wrapper.style.height = '';
      allCards.forEach(c => c.classList.add('visible'));
      buildDots(0);
      return;
    }

    section.classList.remove('no-scroll');
    isScrollMode = true;
    wrapper.style.height = `${window.innerHeight + maxX + PAUSE_PX}px`;

    // Calcola visibili e pagine
    visibleCount = getVisibleCount();
    pageCount    = Math.ceil(allCards.length / visibleCount);
    buildDots(pageCount);
  }

  /* ── Applica posizione e aggiorna dot ── */
  function applyX(x) {
    currentX = Math.min(getMaxX(), Math.max(0, x));
    grid.style.transform = `translateX(-${currentX}px)`;
    updateUI();
  }

  function updateUI() {
    // Dot attivo: quale pagina stiamo guardando
    const gap    = parseInt(getComputedStyle(grid).gap) || 40;
    const cardW  = allCards[0] ? allCards[0].offsetWidth + gap : 360;
    const pageW  = visibleCount * cardW;
    const activePage = pageW > 0 ? Math.round(currentX / pageW) : 0;
    dotEls.forEach((d, i) => d.classList.toggle('active', i === activePage));

    // Frecce disabilitate agli estremi
    if (btnPrev) btnPrev.disabled = currentX <= 0;
    if (btnNext) btnNext.disabled = currentX >= getMaxX();
  }

  /* ── Scroll verticale → orizzontale ── */
  function onScroll() {
    if (!isScrollMode) return;
    const wrapperTop      = wrapper.getBoundingClientRect().top;
    const wrapperH        = wrapper.offsetHeight;
    const viewH           = window.innerHeight;
    const totalScrollable = wrapperH - viewH - PAUSE_PX;
    const scrolled        = -wrapperTop;
    const progress        = Math.min(1, Math.max(0, scrolled / totalScrollable));
    applyX(progress * getMaxX());
  }

  /* ── Init ── */
  function init() {
    setup();
    onScroll();
  }
  requestAnimationFrame(() => requestAnimationFrame(init));

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', () => { setup(); onScroll(); });

  /* ── Frecce: avanzano di una "pagina visibile" ── */
  function cardStep(dir) {
    const gap   = parseInt(getComputedStyle(grid).gap) || 40;
    const cardW = allCards[0] ? allCards[0].offsetWidth + gap : 360;
    applyX(currentX + dir * visibleCount * cardW);
  }
  btnPrev?.addEventListener('click', () => cardStep(-1));
  btnNext?.addEventListener('click', () => cardStep(1));
})();
</script>