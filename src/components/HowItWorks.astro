---
import { howItWorksData } from '../lib/data';
import { readLocalSvg } from '../lib/svg';
const howItWorks = howItWorksData;
const stepSvgs = howItWorks.steps.map(s => readLocalSvg(s.iconFile));
---
<style>
  .how-section {
    background-color: #233f2d;
    color: #ffffff;
    font-family: var(--font-body, system-ui, sans-serif);
    padding: clamp(2.5rem, 5vw, 5rem) 0 clamp(2rem, 4vw, 4rem);
    margin-top: -1px;
  }

  .how-header {
    text-align: center;
    padding: 0 2rem;
    margin-bottom: clamp(1rem, 3vw, 2.5rem);
  }

  .section-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .section-sub {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 700px;
    margin: 0.8rem auto 0;
    line-height: 1.5;
  }

  .how-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .how-grid {
    display: flex;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 4vw, 4.5rem) clamp(2rem, 3vw, 3.5rem);
    transition: transform 0.4s ease;
  }
  .how-grid::after {
    content: '';
    flex-shrink: 0;
    width: clamp(1rem, 4vw, 4.5rem);
    min-height: 1px;
  }

  /* Card */
  .how-card {
    background: #ffffff;
    border-radius: 16px;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.2rem, 2.5vw, 2rem);
    text-align: left;
    position: relative;
    width: clamp(260px, 75vw, 320px);
    flex-shrink: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .how-badge {
    position: absolute;
    top: clamp(-14px, -2vw, -22px);
    left: clamp(-14px, -2vw, -22px);
    width: clamp(32px, 5vw, 44px);
    height: clamp(32px, 5vw, 44px);
    background: #51852a;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.85rem, 1.5vw, 1.15rem);
    font-weight: 400;
  }

  .how-icon-box {
    width: 60px;
    height: 60px;
    background: #cceae0;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .how-icon-box :global(svg) {
    width: 28px;
    height: 28px;
    color: #233f2d;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-card h3 {
    font-size: 1.2rem;
    font-weight: 500;
    color: #111827;
    margin-bottom: 0.8rem;
    line-height: 1.3;
  }
  .how-card p {
    font-size: 0.98rem;
    color: #4b5563;
    line-height: 1.6;
  }

  /* Footer: arrows + dots */
  .how-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 2rem;
  }

  .how-arrows {
    display: flex;
    gap: 0.75rem;
  }
  .how-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    background: transparent;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  }
  .how-arrow:hover:not(:disabled) {
    background: rgba(255,255,255,0.15);
    border-color: white;
  }
  .how-arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }
  .how-arrow svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .how-progress {
    display: flex;
    gap: 7px;
    align-items: center;
  }
  .how-progress-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    transition: background 0.3s, transform 0.3s;
    cursor: pointer;
  }
  .how-progress-dot.active {
    background: #ffffff;
    transform: scale(1.4);
  }

  .section-cta-text {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.65rem 1.4rem;
    border-radius: 99px;
    margin: 0;
    min-width: 220px;
    justify-content: center;
    transition: background 0.2s, transform 0.15s;
  }
  .section-cta-wrap { text-align: center; display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .section-cta-wrap .section-cta-text { width: 280px; white-space: nowrap; }
  .section-cta-text.light {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .section-cta-text.light:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }
  .section-cta-text svg {
    width: 18px;
    height: 18px;
  }
  .section-cta-text svg:last-child {
    animation: nudge-arrow 2s ease-in-out infinite;
  }
  .section-cta-text:hover svg:last-child {
    animation: none;
    transform: translateX(4px);
  }
  @keyframes nudge-arrow {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(5px); }
  }

  /* When all cards fit — hide controls, center cards */
  .how-section.no-carousel .how-grid {
    justify-content: center;
    flex-wrap: wrap;
    padding: 2.5rem 2rem 3rem;
  }
  .how-section.no-carousel .how-card {
    width: clamp(260px, 18vw, 320px);
  }
  .how-section.no-carousel .how-footer {
    display: none;
  }
  .how-section.no-carousel .how-grid::after {
    display: none;
  }
</style>

<section class="how-section" id="howSection">
  <div class="how-header">
    <h2 class="section-title fade-up">{howItWorks.title}</h2>
    <p class="section-sub fade-up">{howItWorks.subtitle}</p>
  </div>

  <div class="how-carousel" id="howCarousel">
    <div class="how-grid" id="howGrid">

      {howItWorks.steps.map((step, i) => (
        <div class="how-card">
          <div class="how-badge">{i + 1}</div>
          <div class="how-icon-box">
            <Fragment set:html={stepSvgs[i]} />
          </div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
      ))}

    </div>
  </div>

  <div class="how-footer" id="howFooter">
    <button class="how-arrow" id="howPrev" disabled>
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="how-progress" id="howProgress"></div>
    <button class="how-arrow" id="howNext">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
  </div>

  <div class="section-cta-wrap">
    <a href="/questionario-utenti" class="section-cta-text light fade-up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Sei un consumatore? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
    <a href="/questionario-produttori" class="section-cta-text light fade-up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg> Sei un produttore? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
  </div>
</section>

<script>
(function () {
  const section    = document.getElementById('howSection');
  const carousel   = document.getElementById('howCarousel');
  const grid       = document.getElementById('howGrid');
  const progressEl = document.getElementById('howProgress');
  const btnPrev    = document.getElementById('howPrev');
  const btnNext    = document.getElementById('howNext');

  if (!carousel || !grid || !section || !progressEl) return;

  const allCards = Array.from(grid.querySelectorAll('.how-card'));
  let currentPage  = 0;
  let pageCount    = 0;
  let dotEls       = [];

  function getCardWidth() {
    const gap = parseInt(getComputedStyle(grid).gap) || 40;
    return allCards[0] ? allCards[0].offsetWidth + gap : 360;
  }

  function getVisibleCount() {
    return Math.max(1, Math.floor(carousel.clientWidth / getCardWidth()));
  }

  function getMaxX() {
    return Math.max(0, grid.scrollWidth - carousel.clientWidth);
  }

  function buildDots(n) {
    progressEl.innerHTML = '';
    dotEls = [];
    for (let i = 0; i < n; i++) {
      const d = document.createElement('div');
      d.className = 'how-progress-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goToPage(i));
      progressEl.appendChild(d);
      dotEls.push(d);
    }
  }

  function goToPage(page) {
    page = Math.max(0, Math.min(page, pageCount - 1));
    currentPage = page;
    const x = Math.min(page * getVisibleCount() * getCardWidth(), getMaxX());
    grid.style.transform = `translateX(-${x}px)`;
    updateUI();
  }

  function updateUI() {
    dotEls.forEach((d, i) => d.classList.toggle('active', i === currentPage));
    if (btnPrev) btnPrev.disabled = currentPage <= 0;
    if (btnNext) btnNext.disabled = currentPage >= pageCount - 1;
  }

  function setup() {
    // Check if all cards fit by comparing total card width to container
    const cardW = getCardWidth();
    const totalCardsWidth = allCards.length * cardW;
    const fits = totalCardsWidth <= carousel.clientWidth + 10;

    if (fits) {
      section.classList.add('no-carousel');
      grid.style.transform = '';
      buildDots(0);
      return;
    }
    section.classList.remove('no-carousel');
    const visible = getVisibleCount();
    pageCount = Math.ceil(allCards.length / visible);
    buildDots(pageCount);
    goToPage(Math.min(currentPage, pageCount - 1));
  }

  // Touch/swipe support
  let touchStartX = 0;
  let touchDeltaX = 0;
  carousel.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchDeltaX = 0;
  }, { passive: true });
  carousel.addEventListener('touchmove', (e) => {
    touchDeltaX = e.touches[0].clientX - touchStartX;
  }, { passive: true });
  carousel.addEventListener('touchend', () => {
    if (Math.abs(touchDeltaX) > 50) {
      goToPage(currentPage + (touchDeltaX < 0 ? 1 : -1));
    }
  });

  btnPrev?.addEventListener('click', () => goToPage(currentPage - 1));
  btnNext?.addEventListener('click', () => goToPage(currentPage + 1));

  if (document.readyState === 'complete') {
    requestAnimationFrame(setup);
  } else {
    window.addEventListener('load', () => requestAnimationFrame(setup));
  }
  window.addEventListener('resize', setup);
})();
</script>