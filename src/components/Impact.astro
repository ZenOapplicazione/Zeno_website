---
import { impactData } from '../lib/data';
const impact = impactData;
const metricSvgs = impact.metrics.map(m => m.iconSvg);
---
<style>
  .impact-section { background: var(--cream); padding: clamp(2.5rem, 5vw, 4rem) clamp(1rem, 3vw, 2rem); }
  .impact-inner { max-width: 80rem; margin: 0 auto; text-align: center; }
  .impact-header { margin-bottom: clamp(2rem, 4vw, 4rem); }
  .impact-header .section-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    font-family: var(--font-display, inherit);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1f2937;
    margin-bottom: 1.5rem; }
  .impact-caption { margin: 0.8rem auto 0;font-size: clamp(0.9rem, 1.2vw, 1.1rem);max-width: 700px; color: #1f2937; }
  .impact-caption strong { font-weight: 700; }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: left;
    align-items: stretch;
  }

  .icard {
    position: relative;
    background-color: var(--card-color, #ffffff);
    background-image: var(--card-img, none);
    background-size: cover;
    background-position: center;
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Spinge il contenuto in basso di default */
    min-height: 340px; /* Altezza minima per gestire il movimento */
    cursor: default;
    transition: box-shadow 0.25s ease;
    overflow: hidden;
  }

  /* Overlay gradiente: bianco in basso, trasparente in alto */
  .icard::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.65) 40%, rgba(255,255,255,0) 65%);
    transition: background 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
    z-index: 0;
  }
  .icard:hover::before {
    background: linear-gradient(to top, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.65) 80%, rgba(255,255,255,0) 100%);
  }

  .icard > * { position: relative; z-index: 1; }
  .icard:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.12); }

  /* Contenitore per animare la salita */
  .icard-content-wrapper {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform: translateY(120px); /* Posizione iniziale (testi in basso) */
  }
  .icard:hover .icard-content-wrapper {
    transform: translateY(0); /* Sale per mostrare le stats */
  }

  .icard-head { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
  .icard-icon {
    width: 36px; height: 36px; background: #1F4D3A; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    color: white; flex-shrink: 0;
  }
  .icard-icon :global(svg) { width: 20px; height: 20px; stroke-width: 2; }
  .icard-title { font-size: 1.05rem; font-weight: 500; color: #1f2937; font-family: var(--font-body); }

  .icard-big-num {
    font-size: clamp(2.5rem, 8vw, 4.5rem); font-weight: 700; color: #1f2937;
    line-height: 1; letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
  }

  /* Stats */
  .icard-stats {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    margin-top: 1rem;
  }
  .icard:hover .icard-stats {
    opacity: 1;
    pointer-events: auto;
  }

  .stat-row { display: flex; flex-direction: column; gap: 0.4rem; }
  .stat-labels { display: flex; justify-content: space-between; align-items: flex-end; }
  .stat-label-title { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; }
  .stat-val { font-size: 0.75rem; font-weight: 600; color: #111827; }
  .bar-gdo { width: 100%; height: 7px; background: #1F4D3A; border-radius: 99px; }
  .bar-zeno-wrapper {
    width: 100%; height: 7px; border: 0.5px solid #000000;
    border-radius: 99px; background: #fff;
    display: flex; align-items: center;
  }
  .bar-zeno-fill { height: 100%; background: #548F2E; border-radius: 99px; transition: width 1s ease; }

  .impact-cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .impact-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--forest-btn, #3e7c59);
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 99px;
    background: rgba(62, 124, 89, 0.08);
    border: 1px solid rgba(62, 124, 89, 0.2);
    transition: background 0.2s, transform 0.15s;
  }

  .impact-cta-link:hover {
    background: rgba(62, 124, 89, 0.15);
    transform: translateY(-1px);
  }

  .impact-cta-link svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .section-cta-wrap { text-align: center; margin-top: clamp(2rem, 4vw, 3rem); }
  .section-cta-text {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--forest-btn, #3e7c59);
    text-decoration: none;
    padding: 0.65rem 1.4rem;
    border-radius: 99px;
    background: rgba(62, 124, 89, 0.08);
    border: 1px solid rgba(62, 124, 89, 0.2);
    transition: background 0.2s, transform 0.15s;
  }
  .section-cta-text:hover { background: rgba(62, 124, 89, 0.15); transform: translateY(-1px); }

  @media (max-width: 992px) {
    .impact-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
    .icard { min-height: 280px; }
    .icard-content-wrapper { transform: translateY(0); }
    .icard-stats { opacity: 1; pointer-events: auto; }
    .icard::before { background: linear-gradient(to top, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.95) 65%, rgba(255,255,255,0) 100%); }
  }
  @media (max-width: 576px) {
    .impact-grid { grid-template-columns: 1fr; gap: 1rem; }
    .icard { padding: 1.2rem; min-height: 240px; }
  }
</style>

<section class="impact-section">
  <div class="impact-inner">
    <div class="impact-header fade-up">
      <h2 class="section-title">{impact.title}</h2>
      <p class="impact-caption" set:html={impact.caption} />
    </div>

    <div class="impact-grid">

      {impact.metrics.map((metric, i) => (
        <div class="icard fade-up" style={`--card-img: url('${metric.backgroundImage}');`}>
          <div class="icard-content-wrapper">
            <div class="icard-head">
              <div class="icard-icon">
                <Fragment set:html={metricSvgs[i]} />
              </div>
              <span class="icard-title">{metric.label}</span>
            </div>
            <div class="icard-big-num">{metric.bigNumber}</div>
            <div class="icard-stats">
              {metric.stats.map((stat, i) => (
                <div class="stat-row">
                  <div class="stat-labels">
                    <span class="stat-label-title">{stat.label}</span>
                    <span class="stat-val">{stat.value}</span>
                  </div>
                  {i === 0 ? (
                    <div class="bar-gdo"></div>
                  ) : (
                    <div class="bar-zeno-wrapper">
                      <div class="bar-zeno-fill" style={`width: ${metric.barPercent}%;`}></div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}

    </div>

  </div>
</section>