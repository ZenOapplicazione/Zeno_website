---
import { groupsData } from '../lib/data';
import { readLocalSvg } from '../lib/svg';
import QuestionariCTA from './QuestionariCTA.astro';
const groups = groupsData;
const cardSvgs = groups.cards.map(c => readLocalSvg(c.iconFile));
---
<style>
  .groups-section {
    background-color: #EAE1C9; 
    padding: clamp(2.5rem, 5vw, 5rem) clamp(1rem, 3vw, 1.5rem);
    font-family: var(--font-body, system-ui, -apple-system, sans-serif);
    color: #111827;
  }

  .groups-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .groups-header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .groups-header h2 {
    font-family: var(--font-display, inherit);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    color: #2E3A28;
  }

  .groups-header p {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    max-width: 700px;
    margin: 0.8rem auto 0;
    color: #4B5563;
  }

  .groups-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* --- CARD BASE --- */
  .gcard {
    background: #ffffff;
    border-radius: 12px;
    padding: 1.8rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03), 0 1px 3px rgba(0, 0, 0, 0.02);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .gcard:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
  }

  /* --- HEADER DELLA CARD --- */
  .gcard-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0; /* Rimosso, gestito ora dal body */
  }

  .gcard-icon {
    width: 48px;
    height: 48px;
    background-color: var(--card-color);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #ffffff; 
  }

  .gcard-icon :global(svg) {
    width: 24px;
    height: 24px;
  }

  .gcard-head h3 {
    font-family: var(--font-body, inherit); 
    font-size: 1.35rem;
    font-weight: 500;
    margin: 0;
    color: #111827;
    line-height: 1.2;
  }

  /* --- CORPO CENTRALE (Magia del centraggio verticale) --- */
  .gcard-body {
    margin-top: auto;
    margin-bottom: auto;
    padding: 1.5rem 0;
  }

  /* --- ETICHETTE E TESTI --- */
  .gcard-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #374151;
    margin-bottom: 0.6rem;
    margin-top: 1.5rem;
  }
  
  .gcard-body .gcard-label:first-child {
    margin-top: 0;
  }

  .gcard-scenario {
    font-size: 0.95rem;
    color: #4B5563;
    line-height: 1.45;
    margin-bottom: 0;
  }

  /* --- LISTE --- */
  .gcard-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .gcard-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: #374151;
    line-height: 1.4;
  }

  .list-arrows li svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--card-color);
  }

  /* --- BOX VALORE GENERATO --- */
  .gcard-value-box {
    background-color: var(--card-color);
    border-radius: 8px;
    padding: 1.4rem;
  }

  .gcard-value-box .gcard-label {
    color: #ffffff;
    margin-top: 0;
  }

  .list-checks li {
    color: #ffffff;
  }

  .list-checks li svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--check-color);
  }


  /* Responsive */
  @media (max-width: 992px) {
    .groups-grid { grid-template-columns: 1fr; max-width: 600px; margin: 0 auto; gap: 1.2rem; }
  }

  @media (max-width: 576px) {
    .groups-grid { gap: 1rem; }
    .gcard { padding: 1rem; }
    .gcard-value-box { padding: 1rem; }
    .gcard-head h3 { font-size: 1.1rem; }
  }
</style>

<section class="groups-section" id="groupsSection">
  <div class="groups-inner">
    <div class="groups-header fade-up">
      <h2>{groups.title}</h2>
      <p>{groups.caption}</p>
    </div>

    <div class="groups-grid">
      {groups.cards.map((card, i) => (
        <div class="gcard fade-up" style={`--card-color: ${card.color}; --check-color: ${card.checkColor};`}>
          <div class="gcard-head">
            <div class="gcard-icon">
              <Fragment set:html={cardSvgs[i]} />
            </div>
            <h3>{card.title}</h3>
          </div>

          <div class="gcard-body">
            <div class="gcard-label">SCENARIO</div>
            <p class="gcard-scenario">{card.scenario}</p>

            <div class="gcard-label">COME USANO L'APP</div>
            <ul class="gcard-list list-arrows">
              {card.howTheyUse.map((item) => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  <span>{item.text}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="gcard-value-box">
            <div class="gcard-label">VALORE GENERATO</div>
            <ul class="gcard-list list-checks">
              {card.value.map((item) => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  <span>{item.text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <QuestionariCTA variant="ghost" />
  </div>
</section>