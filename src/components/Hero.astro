---
// src/components/Hero.astro
---
<style>
    .hero-bg-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: #e9ebe8;
        will-change: transform, height;
        overflow: hidden;
        height: 100vh;
    }

    .navbar-hero {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        position: relative;
        transform-origin: top center;
        max-width: 1600px;
        margin: 0 auto;
    }

    .hero-image {
        flex: 1;
        height: 100dvh;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        position: relative;
        z-index: 1;
    }

    .hero-image img {
        max-height: 120vh;
        max-width: 200%;
        object-fit: contain;
        object-position: bottom right;
        margin-left: -15vw;
        margin-right: -5%;
    }

    .hero-top-mobile {
        display: none;
    }

    .hero-content {
        flex: 1.1;
        padding: 2rem 4rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        z-index: 2;
        margin-right: 10%;
    }

    /* TITOLO: Cameric Bold */
    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(5rem, 8.5vw, 9rem);
        color: #ff5e14;
        line-height: 0.7;
        letter-spacing: -0.03em;
        font-weight: 700;
        will-change: transform, opacity;
    }

    /* SOTTOTITOLO: Inter Medium */
    .hero-sub {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: clamp(1.2rem, 2.5vw, 2.2rem);
        color: #ff5e14;
        margin-bottom: 1.5rem;
        margin-top: 1.5rem;
        line-height: 1.0;
        will-change: transform, opacity;
    }

    .hero-btns-row {
        display: flex;
        gap: 1rem;
        flex-direction: row;
        margin-bottom: 0;
        will-change: transform, opacity;
        width: 90%;
    }

    /* BOTTONI: Inter Medium */
    .btn-produttori,
    .btn-consumatori {
        display: flex;
        justify-content: center;
        align-items: center;
        align-self: stretch;
        border-radius: 14px;
        flex: 1;
        padding: 1.1rem 1.5rem;
        font-family: var(--font-body);
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: background .2s, transform .15s;
        text-decoration: none;
    }

    .btn-consumatori {
        background: #1F4D3A;
        color: #ffffff;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.10), 0 4px 6px -4px rgba(0, 0, 0, 0.10);
    }

    .btn-consumatori:hover {
        background: #122d22;
        transform: translateY(-1px);
    }

    .btn-produttori {
        background: #FFF;
        color: #016630;
        border: 1.52px solid #016630;
    }

    .btn-produttori:hover {
        background: #f0f7f3;
        transform: translateY(-1px);
    }

    .hero-email-row {
        margin-top: 2rem;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
        width: 90%;
        margin-bottom: 2rem;
        will-change: transform, opacity;
        padding: 20px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.5);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.10), 0 2px 4px -2px rgba(0, 0, 0, 0.10);
    }

    /* INPUT: Inter Regular */
    .hero-email-row input {
        flex: 1;
        min-width: 400px;
        padding: 12px 16px;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 0.95rem;
        background: transparent;
        color: #333;
        outline: none;
        transition: border-color .2s;
    }

    .hero-email-row input:focus {
        border-color: #2a563d;
    }

    /* BOTTONE ISCRIVITI: Inter Medium */
    .btn-green-light {
        background: #1F6D3A;
        color: #ffffff;
        padding: 12px;
        border-radius: 10px;
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 0.95rem;
        cursor: pointer;
        border: none;
        width: 100%;
        transition: background .2s;
    }

    .btn-green-light:hover {
        background: #185a2f;
    }

    /* LINK CONTATTI: Inter Medium */
    .hero-contact-link {
        font-family: var(--font-body);
        font-weight: 500;
        color: #ff5e14;
        font-size: 1.1rem;
        will-change: opacity;
        padding-top: 8px;
        text-decoration: underline;
    }

    .hero-contact-link:hover {
        text-decoration: underline;
    }

    .hero-arrow {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        color: #ff5e14;
        animation: bounce 2s ease-in-out infinite;
        will-change: opacity;
        z-index: 3;
    }

    .hero-arrow svg {
        width: 32px;
        height: 32px;
        stroke-width: 2.5;
    }

    .hero-email-success {
        font-size: 1rem;
        color: #2e3a28;
        font-weight: 500;
        margin: 0 auto;
    }

    @keyframes bounce {
        0%, 100% {
            transform: translateX(-50%) translateY(0);
        }
        50% {
            transform: translateX(-50%) translateY(8px);
        }
    }

    .hero-spacer {
        height: 100vh;
        margin: 0;
        padding: 0;
    }

    @media (max-width: 992px) {
        .navbar-hero {
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding-top: 0;
            min-height: 100dvh;
            position: relative;
            justify-content: flex-start;
        }

        /* Top section: white bg with just the title */
        .hero-top-mobile {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            width: 100%;
            min-height: 16dvh;
            background: #F9FAFB;
            position: relative;
            z-index: 3;
            padding: 1rem 2rem 0;
            margin-bottom: -1px;
        }

        .hero-top-mobile .hero-title {
            font-size: clamp(4rem, 10vw, 5rem);
            margin-bottom: 10px;
        }

        /* Bottom section: cow background with content */
        .navbar-hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            background-image: url('/images/mucca-mobile.png');
            background-size: min(100%, 450px);
            background-position: center bottom;
            background-repeat: no-repeat;
            z-index: 0;
        }

        .hero-image {
            display: none;
        }

        /* Hide the title inside hero-content on mobile (shown in hero-top-mobile) */
        .hero-content .hero-title {
            display: none;
        }

        .hero-content {
            flex: 1;
            padding: 1.5rem clamp(1.5rem, 5vw, 3rem);
            margin: 0 auto;
            justify-content: flex-start;
            align-items: center;
            text-align: center;
            width: 100%;
            max-width: 600px;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: clamp(1.2rem, 3vw, 2rem);
        }

        .hero-sub {
            font-size: clamp(1rem, 2.5vw, 1.4rem);
            margin-top: 0;
            margin-bottom: 0;
        }

        .hero-btns-row {
            justify-content: center;
            align-items: center;
            align-self: center;
            flex-direction: column;
            max-width: 400px;
            width: 100%;
            gap: 0.7rem;
            margin-top: auto;
            transform: translateY(5dvh);
        }

        .btn-produttori,
        .btn-consumatori {
            width: 100%;
        }

        .hero-email-row {
            flex-direction: column;
            align-items: flex-start;
            align-self: center;
            max-width: 400px;
            width: 100%;
            margin-top: 10dvh;
            padding: 20px;
            gap: 12px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.10), 0 2px 4px -2px rgba(0, 0, 0, 0.10);
        }

        .hero-email-row input {
            width: 100%;
            flex: none;
            border: 1px solid #D1D5DB;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 0.95rem;
            background: transparent;
            color: #333;
        }

        .hero-email-row .btn-green-light {
            width: 100%;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.95rem;
            background: #1F6D3A;
        }

        .hero-contact-link {
            margin-bottom: auto;
            margin-left: 0;
            margin-top: 10dvh;
        }

        .hero-arrow {
            display: none;
        }
    }

    @media (max-width: 375px) {
        .hero-contact-link {
            margin-top: 1dvh;
        }
        .navbar-hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            background-image: url('/images/mucca-mobile.png');
            background-size: 100%;
            background-position: center calc(100% - (1px - 100vw) * 0.25);
            background-repeat: no-repeat;
            z-index: 0;
        }
    }

</style>

<div class="hero-bg-wrapper" id="hero-bg-wrapper">
  <div class="navbar-hero" id="navbar-hero">
    
    <div class="hero-image">
      <img src="/images/mucca.png" alt="Mucca ZenO" loading="eager" fetchpriority="high"/>
    </div>

    <div class="hero-top-mobile">
      <h1 class="hero-title" id="hero-title">ZenO</h1>
    </div>

    <div class="hero-content">
      <h1 class="hero-title hero-title-desktop">ZenO</h1>
      <p class="hero-sub" id="hero-sub">La spesa consapevole,<br>semplificata e condivisa.</p>

      <div class="hero-btns-row" id="hero-btns">
        <a href="/questionario-utenti" class="btn-consumatori">Questionario consumatori</a>
        <a href="/questionario-produttori" class="btn-produttori">Questionario produttori</a>
      </div>

      <form class="hero-email-row" id="hero-email">
        <input type="email" name="email" id="hero-email-input"
               placeholder="La tua email" required>
        <button type="submit" id="hero-email-btn" class="btn-green-light">Ricevi aggiornamenti</button>
      </form>

      <script>
        document.getElementById('hero-email').addEventListener('submit', async function (e) {
          e.preventDefault();
          const form = e.target;
          const input = document.getElementById('hero-email-input');
          const btn = document.getElementById('hero-email-btn');
          const data = new FormData(form);

          try {
            const res = await fetch('https://formspree.io/f/maqlddnl', {
              method: 'POST',
              body: data,
              headers: {'Accept': 'application/json'}
            });

            if (res.ok) {
              input.value = 'Grazie, sarai aggiornato presto! 🌱';
              input.readOnly = true;
              input.style.background = '#e8f0e3';
              input.style.color = '#2e3a28';
              input.style.fontWeight = '500';
              btn.disabled = true;
              btn.style.opacity = '0.4';
              btn.style.cursor = 'default';
            }
          } catch (err) {
            console.error(err);
          }
        });
      </script>

      <a href="#" class="hero-contact-link" id="hero-contact">Hai domande? Scrivici</a>
    </div>

    <div class="hero-arrow" id="hero-arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</div>

<div class="hero-spacer" id="top"></div>

<script is:inline>
  const heroWrapper = document.getElementById('hero-bg-wrapper');
  const hero = document.getElementById('navbar-hero');
  const navbarTop = document.getElementById('navbar-top');
  const title = document.getElementById('hero-title');
  const sub = document.getElementById('hero-sub');
  const emailRow = document.getElementById('hero-email');
  const btns = document.getElementById('hero-btns');
  const arrow = document.getElementById('hero-arrow');
  const contact = document.getElementById('hero-contact');

  const NAV_H = 64;
  const HERO_H = window.innerHeight;

  function easeInOut(t) {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  let ticking = false;

  function update() {
    const scrollY = window.scrollY;
    const raw = Math.min(scrollY / (HERO_H * 0.65), 1);
    const p = easeInOut(raw);
    if (heroWrapper) {
      heroWrapper.style.height = scrollY === 0 ? '100vh' : Math.max(HERO_H - scrollY, NAV_H) + 'px';
      heroWrapper.style.boxShadow = `0 2px 20px rgba(0,0,0,${lerp(0, 0.1, p)})`;
    }
    if (hero) {
      hero.style.transform = `scale(${lerp(1, 0.95, p)})`;
      hero.style.opacity = lerp(1, 0, p);
    }
    const fadeO = lerp(1, 0, easeInOut(Math.min(raw / 0.55, 1)));
    if (title) title.style.opacity = fadeO;
    if (sub) sub.style.opacity = fadeO;
    const elO = lerp(1, 0, easeInOut(Math.max(0, Math.min((raw - 0.05) / 0.45, 1))));
    if (emailRow) emailRow.style.opacity = elO;
    if (btns) btns.style.opacity = elO;
    if (arrow) arrow.style.opacity = elO;
    if (contact) contact.style.opacity = elO;
    const pe = p > 0.8 ? 'none' : 'auto';
    if (emailRow) emailRow.style.pointerEvents = pe;
    if (btns) btns.style.pointerEvents = pe;
    if (contact) contact.style.pointerEvents = pe;
    const barP = Math.max(0, Math.min((p - 0.6) / 0.4, 1));
    if (navbarTop) {
      navbarTop.style.opacity = barP;
      navbarTop.style.pointerEvents = barP > 0.1 ? 'auto' : 'none';
    }
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }, {passive: true});
  update();
</script>