---
import { getHero } from '../lib/strapi';
import { marked } from 'marked';
const hero = await getHero();
const whatsappHtml = hero.whatsappText ? marked.parse(hero.whatsappText) : '';
---

<style>
    .hero-bg-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: #e9ebe8;
        will-change: transform, height;
        overflow: hidden;
        height: 100vh;
    }

    .navbar-hero {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        position: relative;
        transform-origin: top center;
        max-width: 1600px;
        margin: 0 auto;
    }

    .hero-image {
        flex: 1;
        height: 100dvh;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        position: relative;
        z-index: 1;
    }

    .hero-image img {
        max-height: 120vh;
        max-width: 200%;
        object-fit: contain;
        object-position: bottom right;
        margin-left: -15vw;
        margin-right: -5%;
    }

    .hero-top-mobile {
        display: none;
    }

    .hero-content {
        flex: 1.1;
        padding: 2rem 4rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        z-index: 2;
        margin-right: 10%;
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(5rem, 8.5vw, 9rem);
        color: #ff5e14;
        line-height: 0.7;
        letter-spacing: -0.03em;
        font-weight: 700;
        will-change: transform, opacity;
    }

    .hero-sub {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: clamp(1.2rem, 2.5vw, 2.2rem);
        color: #ff5e14;
        margin-bottom: 1.5rem;
        margin-top: 1.5rem;
        line-height: 1.0;
        will-change: transform, opacity;
    }

    /* WhatsApp Card */
    .whatsapp-card {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        background: rgba(255, 255, 255, 0.92);
        border-radius: 16px;
        padding: 1.5rem 1.8rem;
        width: 90%;
        max-width: 520px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        will-change: transform, opacity;
    }

    .whatsapp-text {
        flex: 1;
        font-family: var(--font-body);
        font-size: 0.92rem;
        color: #333;
        line-height: 1.55;
        text-align: left;
    }

    .whatsapp-text :global(strong) {
        font-weight: 700;
    }

    .whatsapp-text :global(p) {
        margin: 0 0 0.3rem 0;
    }

    .whatsapp-text :global(p:last-child) {
        margin-bottom: 0;
    }

    .whatsapp-icon-btn {
        flex-shrink: 0;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #25D366;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
        text-decoration: none;
    }

    .whatsapp-icon-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(37, 211, 102, 0.4);
    }

    .whatsapp-icon-btn svg {
        width: 28px;
        height: 28px;
        fill: white;
    }

    /* Mobile full button (hidden on desktop) */
    .whatsapp-full-btn {
        display: none;
    }

    .hero-arrow {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        color: #ff5e14;
        animation: bounce 2s ease-in-out infinite;
        will-change: opacity;
        z-index: 3;
    }

    .hero-arrow svg {
        width: 32px;
        height: 32px;
        stroke-width: 2.5;
    }

    @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(8px); }
    }

    .hero-spacer {
        height: 100vh;
        margin: 0;
        padding: 0;
    }

    @media (max-width: 992px) {
        .navbar-hero {
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding-top: 0;
            min-height: 100dvh;
            position: relative;
            justify-content: flex-start;
        }

        .hero-top-mobile {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            width: 100%;
            min-height: 16dvh;
            position: relative;
            z-index: 3;
            padding: 1rem 2rem 0;
            margin-bottom: -1px;
        }

        .hero-top-mobile .hero-title {
            font-size: clamp(4.5rem, 10vw, 5rem);
            margin-bottom: 10px;
        }

        .navbar-hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            opacity: 0.8;
            background-image: var(--mobileImageUrl);
            background-size: min(100%, 450px);
            background-position: center calc(100% - (200px - 100vw) * 0.1);
            background-repeat: no-repeat;
            z-index: 0;
        }

        .hero-image {
            display: none;
        }

        .hero-content .hero-title {
            display: none;
        }

        .hero-content {
            flex: 1;
            padding: 1.5rem clamp(1.5rem, 5vw, 3rem);
            margin: 0 auto;
            justify-content: flex-start;
            align-items: center;
            text-align: center;
            width: 100%;
            max-width: 600px;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: clamp(1.2rem, 3vw, 2rem);
        }

        .hero-sub {
            font-size: clamp(1.3rem, 2.5vw, 1.4rem);
            margin-top: 0;
            margin-bottom: 0;
        }

        .whatsapp-card {
            flex-direction: column;
            align-items: stretch;
            text-align: left;
            width: 100%;
            max-width: 400px;
            padding: 1.5rem;
            background: rgba(255, 255, 255, 0.95);
        }

        .whatsapp-icon-btn {
            display: none;
        }

        .whatsapp-full-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            width: 100%;
            padding: 0.9rem 1.5rem;
            background: #25D366;
            color: white;
            border: none;
            border-radius: 12px;
            font-family: var(--font-body);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s, transform 0.15s;
            box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
            margin-top: 0.5rem;
        }

        .whatsapp-full-btn:hover {
            background: #1EB954;
            transform: translateY(-1px);
        }

        .whatsapp-full-btn svg {
            width: 22px;
            height: 22px;
            fill: white;
        }

        .hero-arrow {
            display: none;
        }
    }

    @media (max-width: 375px) {
        .navbar-hero::after {
            background-size: 100%;
            background-position: center calc(100% - (1px - 100vw) * 0.25);
        }
    }
</style>

<style define:vars={{ mobileImageUrl: `url(${hero.mobileImage.url})` }}>
</style>

<div class="hero-bg-wrapper" id="hero-bg-wrapper">
  <div class="navbar-hero" id="navbar-hero">

    <div class="hero-image">
      <img src={hero.desktopImage.url} alt={hero.desktopImage.alternativeText || hero.title} loading="eager" fetchpriority="high"/>
    </div>

    <div class="hero-top-mobile">
      <h1 class="hero-title" id="hero-title">{hero.title}</h1>
    </div>

    <div class="hero-content">
      <h1 class="hero-title hero-title-desktop">{hero.title}</h1>
      <p class="hero-sub" id="hero-sub">{hero.subtitle}</p>

      <div class="whatsapp-card" id="hero-wa-card">
        <div class="whatsapp-text" set:html={whatsappHtml} />
        <a href={hero.whatsappLink} target="_blank" rel="noopener noreferrer" class="whatsapp-icon-btn" title="WhatsApp">
          <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href={hero.whatsappLink} target="_blank" rel="noopener noreferrer" class="whatsapp-full-btn">
          <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {hero.whatsappButtonText}
        </a>
      </div>
    </div>

    <div class="hero-arrow" id="hero-arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</div>

<div class="hero-spacer" id="top"></div>

<script is:inline>
  const heroWrapper = document.getElementById('hero-bg-wrapper');
  const hero = document.getElementById('navbar-hero');
  const navbarTop = document.getElementById('navbar-top');
  const title = document.getElementById('hero-title');
  const sub = document.getElementById('hero-sub');
  const waCard = document.getElementById('hero-wa-card');
  const arrow = document.getElementById('hero-arrow');

  const NAV_H = 64;
  const HERO_H = window.innerHeight;

  function easeInOut(t) {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  let ticking = false;

  function update() {
    const scrollY = window.scrollY;
    const raw = Math.min(scrollY / (HERO_H * 0.65), 1);
    const p = easeInOut(raw);
    if (heroWrapper) {
      heroWrapper.style.height = scrollY === 0 ? '100vh' : Math.max(HERO_H - scrollY, NAV_H) + 'px';
      heroWrapper.style.boxShadow = `0 2px 20px rgba(0,0,0,${lerp(0, 0.1, p)})`;
    }
    if (hero) {
      hero.style.transform = `scale(${lerp(1, 0.95, p)})`;
      hero.style.opacity = lerp(1, 0, p);
    }
    const fadeO = lerp(1, 0, easeInOut(Math.min(raw / 0.55, 1)));
    if (title) title.style.opacity = fadeO;
    if (sub) sub.style.opacity = fadeO;
    const elO = lerp(1, 0, easeInOut(Math.max(0, Math.min((raw - 0.05) / 0.45, 1))));
    if (waCard) waCard.style.opacity = elO;
    if (arrow) arrow.style.opacity = elO;
    const pe = p > 0.8 ? 'none' : 'auto';
    if (waCard) waCard.style.pointerEvents = pe;
    const barP = Math.max(0, Math.min((p - 0.6) / 0.4, 1));
    if (navbarTop) {
      navbarTop.style.opacity = barP;
      navbarTop.style.pointerEvents = barP > 0.1 ? 'auto' : 'none';
    }
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }, {passive: true});
  update();
</script>