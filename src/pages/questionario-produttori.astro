  <div class="success-overlay" id="successOverlay">
    <div class="success-card">
      <span class="success-emoji">🌿</span>
      <div class="success-title">Grazie mille!</div>
      <p class="success-msg">Le vostre risposte sono state inviate con successo. Aiuteranno ZenO a costruire un servizio che funzioni davvero per i produttori e le loro comunità.</p>
      <a href="/" class="btn-close-success">Torna alla home</a>
    </div>
  </div>

  <script>
    const form = document.getElementById('zenoForm');

    // ── ENTRY MAP (nomi locali → entry ID Google Forms) ──
    // I codici entry._sentinel vanno usati SENZA _sentinel
    const ENTRY_MAP = {
      'entry.TIPO_AZIENDA':        'entry.1513251518',
      'entry.DOVE_OPERI':          'entry.684289151',
      'entry.CERTIFICAZIONI':      'entry.1518617442',
      'entry.PRODOTTI':            'entry.887799752',
      'entry.CANALI':              'entry.1213719826',
      'entry.FATTURATO_GAS':       'entry.1136991269',
      'entry.NUM_GAS':             'entry.951969551',
      'entry.GESTIONE_ORDINI':     'entry.85366835',
      'entry.FREQUENZA_ORDINI':    'entry.716303712',
      'entry.TEMPO_CONSOLIDAMENTO':'entry.380024575',
      'entry.MIGLIORAMENTO':       'entry.1365293826',
      'entry.CONSEGNE':            'entry.613094316',
      'entry.RAGGIO_CONSEGNA':     'entry.491690880',
      'entry.MINIMO_ORDINE':       'entry.497779236',
      'entry.AUMENTARE_PROD':      'entry.1083259953',
      'entry.SOFTWARE':            'entry.1109006643',
      'entry.DESIDERATA':          'entry.824295861',
      'entry.RISCHI':              'entry.1314224554',
      'entry.VISITE':              'entry.503805638',
      'entry.UTILITA':             'entry.1576538096',
      'entry.EMAIL':               'entry.83001105', // campo email — aggiorna con entry corretto
    };

    // ── ALTRO: mostra/nascondi campo testo ──
    function setupAltro(radioOrCheckId, textInputId) {
      const trigger = document.getElementById(radioOrCheckId);
      const textEl  = document.getElementById(textInputId);
      if (!trigger || !textEl) return;
      const update = () => {
        textEl.style.display = trigger.checked ? 'block' : 'none';
        if (!trigger.checked) textEl.value = '';
      };
      trigger.addEventListener('change', update);
      // Per radio: anche gli altri del gruppo devono nascondere il campo
      if (trigger.type === 'radio') {
        form.querySelectorAll(`input[name="${trigger.name}"]`).forEach(r => {
          if (r !== trigger) r.addEventListener('change', update);
        });
      }
      update();
    }
    setupAltro('altroTipoRadio',  'altroTipoText');
    setupAltro('altroOrdiniRadio','altroOrdiniText');
    setupAltro('altroCertCheck',  'altroCertText');
    setupAltro('altroMiglCheck',  'altroMiglText');

    // ── PROGRESS BAR ──
    const TRACKED = [
      'entry.TIPO_AZIENDA','entry.DOVE_OPERI','entry.CERTIFICAZIONI',
      'entry.PRODOTTI','entry.CANALI','entry.NUM_GAS',
      'entry.GESTIONE_ORDINI','entry.MIGLIORAMENTO','entry.CONSEGNE',
      'entry.RAGGIO_CONSEGNA','entry.AUMENTARE_PROD','entry.DESIDERATA',
      'entry.VISITE','entry.UTILITA'
    ];
    function updateProgress() {
      const answered = new Set();
      form.querySelectorAll('input[type=radio]:checked, input[type=checkbox]:checked')
          .forEach(i => answered.add(i.name));
      form.querySelectorAll('input[type=text], input[type=email], input[type=number], textarea')
          .forEach(i => { if (i.name && i.value.trim()) answered.add(i.name); });
      const pct = Math.round((answered.size / TRACKED.length) * 100);
      document.getElementById('progressFill').style.width = Math.min(pct, 100) + '%';
      document.getElementById('progressPct').textContent  = Math.min(pct, 100) + '%';
    }
    form.addEventListener('change', updateProgress);
    form.addEventListener('input',  updateProgress);

    // ── VALIDAZIONE ──
    function getCard(name) {
      const el = form.querySelector(`[name="${name}"]`);
      return el ? el.closest('.q-card') : null;
    }
    function showError(card, msg) {
      card.classList.add('has-error');
      if (!card.querySelector('.q-error')) {
        const d = document.createElement('div');
        d.className = 'q-error'; d.textContent = '⚠ ' + msg;
        card.appendChild(d);
      }
    }
    function clearErrors() {
      form.querySelectorAll('.has-error').forEach(c => {
        c.classList.remove('has-error');
        c.querySelectorAll('.q-error').forEach(e => e.remove());
      });
    }
    form.addEventListener('change', e => {
      const c = e.target.closest('.q-card');
      if (c) { c.classList.remove('has-error'); c.querySelectorAll('.q-error').forEach(e => e.remove()); }
    });

    const REQUIRED = [
      'entry.TIPO_AZIENDA','entry.DOVE_OPERI','entry.PRODOTTI',
      'entry.CANALI','entry.NUM_GAS','entry.GESTIONE_ORDINI',
      'entry.CONSEGNE','entry.RAGGIO_CONSEGNA','entry.AUMENTARE_PROD',
      'entry.DESIDERATA','entry.VISITE','entry.UTILITA'
    ];

    function validate() {
      clearErrors();
      let firstErr = null;
      let ok = true;
      for (const name of REQUIRED) {
        const card = getCard(name);
        if (!card) continue;
        const inputs = form.querySelectorAll(`[name="${name}"]`);
        const type   = inputs[0]?.type;
        let answered = false;
        if (type === 'radio' || type === 'checkbox') {
          answered = !!form.querySelector(`[name="${name}"]:checked`);
        } else {
          answered = inputs[0]?.value.trim().length >= 1;
        }
        if (!answered) {
          showError(card, type === 'radio' || type === 'checkbox' ? "Seleziona un'opzione." : 'Campo obbligatorio.');
          if (!firstErr) firstErr = card;
          ok = false;
        }
      }
      // email format
      const emailEl = form.querySelector('[name="entry.EMAIL"]');
      if (emailEl?.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
        const c = emailEl.closest('.q-card');
        showError(c, 'Inserisci un indirizzo email valido.');
        if (!firstErr) firstErr = c;
        ok = false;
      }
      if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return ok;
    }

    // ── SUBMIT ──
    form.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!validate()) return;

  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Invio in corso…';

  const data = new FormData(form);
  const params = new URLSearchParams();

  // 1. Mappatura dei campi come facevi prima [cite: 175]
  for (const [ourKey, googleKey] of Object.entries(ENTRY_MAP)) {
    const vals = data.getAll(ourKey).filter(v => v.trim());
    const altroMap = {
      'entry.TIPO_AZIENDA': 'entry.TIPO_AZIENDA_ALTRO',
      'entry.GESTIONE_ORDINI': 'entry.GESTIONE_ORDINI_ALTRO',
    };

    if (altroMap[ourKey]) {
      const altroVal = data.get(altroMap[ourKey])?.trim();
      vals.forEach(v => {
        params.append(googleKey, v === 'Altro' && altroVal ? 'Altro: ' + altroVal : v);
      });
    } else {
      vals.forEach(v => params.append(googleKey, v));
    }
  }

  // 2. Aggiunta campi Altro per checkbox [cite: 178, 179]
  const certAltro = data.get('entry.CERTIFICAZIONI_ALTRO')?.trim();
  if (certAltro) params.append('entry.1518617442', 'Altro: ' + certAltro);
  const miglAltro = data.get('entry.MIGLIORAMENTO_ALTRO')?.trim();
  if (miglAltro) params.append('entry.1365293826', 'Altro: ' + miglAltro);

  // 3. INVIO DIRETTO A GOOGLE FORMS
  const GOOGLE_FORM_ACTION = "https://docs.google.com/forms/d/e/1FAIpQLScvvwYovq5yB4kJZYcuuEEypdY25B98oAavAhGugnXp-GbuGA/formResponse";

  try {
    // Usiamo mode: 'no-cors' per evitare il blocco CORS di Google.
    // Importante: con 'no-cors' non potrai leggere la risposta (sarà opaca), 
    // ma il dato verrà inviato correttamente.
    await fetch(GOOGLE_FORM_ACTION, {
      method: 'POST',
      mode: 'no-cors',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: params.toString()
    });

    // Se arriviamo qui, consideriamo l'invio riuscito 
    document.getElementById('successOverlay').classList.add('show');
  } catch (err) {
    console.error(err);
    alert('Errore di connessione. Riprova tra poco.');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Invia il questionario';
  }
});

    // ── FADE UP ──
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
  </script>

</BaseLayout>