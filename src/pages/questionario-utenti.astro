---
// questionario-utenti.astro – ZenO User Questionnaire
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZenO | Questionario Utenti">
  <style>
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--text-dark); background: rgb(242, 239, 232); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* NAVBAR */
    .navbar { position: sticky; top: 0; z-index: 100; background: var(--navbar-bg); height: 64px; display: flex; align-items: center; justify-content: space-between; padding: 0 2.5rem; box-shadow: 0 2px 20px rgba(0,0,0,0.06); }
    .nav-logo { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: #ff5e14; letter-spacing: -0.02em; text-decoration: none; }
    .nav-back { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-mid); text-decoration: none; transition: color .2s; }
    .nav-back:hover { color: var(--forest); }

    /* HERO */
    .form-hero { background: var(--forest); padding: 4rem 2rem 5rem; text-align: center; }
    .form-eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(13, 204, 13, 0.36); border-radius: 99px; padding: 0.35rem 1rem; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--white); margin-bottom: 1.5rem; }
    .form-hero-title {  font-family: var(--font-display, inherit);
    font-size: clamp(2.5rem, 5vw, 4.5rem); 
    font-weight: 300; color: var(--white); line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 1rem; }
    .form-hero-sub { font-size: 1rem; font-weight: 300; color: var(--white); opacity: 0.7; max-width: 500px; margin: 0 auto 1.5rem; line-height: 1.6; }
    .form-hero-meta { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
    .meta-pill { display: flex; align-items: center;padding: 0.6rem 1.2rem; gap: 0.4rem; font-size: 0.78rem; color: var(--white); }
    .meta-pill svg { width: 16px; height: 16px; }

    /* PROGRESS */
    .progress-wrap { background: rgb(236, 234, 225); padding: 1.2rem 2rem; position: sticky; top: 64px; z-index: 90; border-bottom: 1px solid var(--border-card); }
    .progress-inner { max-width: 720px; margin: 0 auto; display: flex; align-items: center; gap: 1rem; }
    .progress-label { font-size: 0.72rem; font-weight: 600; color: var(--text-muted); white-space: nowrap; }
    .progress-track { flex: 1; height: 5px; background: rgba(45,74,45,0.12); border-radius: 99px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--forest-btn); border-radius: 99px; transition: width .4s cubic-bezier(0.34,1.56,0.64,1); width: 0%; }
    .progress-pct { font-size: 0.72rem; font-weight: 700; color: var(--forest); white-space: nowrap; min-width: 32px; text-align: right; }

    /* FORM LAYOUT */
    .form-body { max-width: 720px; margin: 0 auto; padding: 3rem 2rem 6rem; }
    .form-section { margin-bottom: 2.5rem; }
    .section-label { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1.5rem; }
    .section-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--sage-pale); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .section-icon svg { width: 18px; height: 18px; stroke: var(--forest); }
    .section-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--text-dark); }
    .section-divider { width: 100%; height: 1px; background: var(--border-card); margin-bottom: 2rem; }

    /* CARDS */
    .q-card { background: var(--white); border: 1px solid var(--border-card); border-radius: 16px; padding: 1.6rem 1.8rem; margin-bottom: 1rem; transition: box-shadow .2s, border-color .2s; }
    .q-card:focus-within { border-color: var(--sage); box-shadow: 0 0 0 3px rgba(140,166,122,0.15); }
    .q-label { font-size: 0.9rem; font-weight: 600; color: var(--text-dark); margin-bottom: 0.3rem; line-height: 1.4; }
    .q-hint { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.5; }

    /* INPUTS */
    .q-input, .q-textarea { width: 100%; padding: 0.75rem 1rem; border: 1.5px solid rgba(45,74,45,0.15); border-radius: 10px; font-family: var(--font-body); font-size: 0.9rem; color: var(--text-dark); background: var(--cream); outline: none; transition: border-color .2s, background .2s; resize: vertical; }
    .q-input:focus, .q-textarea:focus { border-color: var(--sage); background: var(--white); }
    .q-input::placeholder, .q-textarea::placeholder { color: var(--text-muted); }
    .q-textarea { min-height: 90px; }

    /* OPTIONS */
    .options-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .options-list.inline { flex-direction: row; flex-wrap: wrap; }
    .opt { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1rem; border: 1.5px solid rgba(45,74,45,0.12); border-radius: 10px; cursor: pointer; transition: border-color .2s, background .2s; user-select: none; }
    .opt:hover { border-color: var(--sage); background: var(--sage-pale); }
    .opt input[type="radio"], .opt input[type="checkbox"] { appearance: none; -webkit-appearance: none; width: 18px; height: 18px; flex-shrink: 0; border: 2px solid rgba(45,74,45,0.25); border-radius: 50%; cursor: pointer; transition: border-color .2s, background .2s; position: relative; }
    .opt input[type="checkbox"] { border-radius: 5px; }
    .opt input[type="radio"]:checked, .opt input[type="checkbox"]:checked { background: var(--forest-btn); border-color: var(--forest-btn); }
    .opt input[type="radio"]:checked::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 6px; height: 6px; border-radius: 50%; background: white; }
    .opt input[type="checkbox"]:checked::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%) rotate(45deg); width: 5px; height: 9px; border-right: 2px solid white; border-bottom: 2px solid white; margin-top: -1px; }
    .opt:has(input:checked) { border-color: var(--sage); background: var(--sage-pale); }
    .opt-text { font-size: 0.875rem; color: var(--text-mid); line-height: 1.4; }

    /* SUBMIT */
    .submit-section { background: var(--white); border: 1px solid var(--border-card); border-radius: 20px; padding: 2.5rem 2rem; text-align: center; margin-top: 2rem; }
    .submit-icon { width: 56px; height: 56px; background: var(--sage-pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; }
    .submit-icon svg { width: 26px; height: 26px; stroke: var(--forest); }
    .submit-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.5rem; }
    .submit-sub { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.8rem; line-height: 1.6; }
    .btn-submit { padding: 1rem 3rem; background: var(--forest-btn); color: white; border: none; border-radius: 12px; font-family: var(--font-body); font-size: 1rem; font-weight: 600; cursor: pointer; transition: background .2s, transform .15s, box-shadow .2s; box-shadow: 0 4px 14px rgba(74,103,65,0.25); }
    .btn-submit:hover { background: var(--forest); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(74,103,65,0.3); }
    .btn-submit:disabled { background: var(--sage-light); cursor: not-allowed; transform: none; box-shadow: none; }

    /* SUCCESS */
    .success-overlay { display: none; position: fixed; inset: 0; z-index: 200; background: rgba(26,36,22,0.6); backdrop-filter: blur(6px); align-items: center; justify-content: center; padding: 2rem; }
    .success-overlay.show { display: flex; }
    .success-card { background: var(--white); border-radius: 24px; padding: 3rem 2.5rem; max-width: 440px; width: 100%; text-align: center; animation: popIn .5s cubic-bezier(0.34,1.56,0.64,1); }
    @keyframes popIn { from { opacity: 0; transform: scale(0.85) translateY(20px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .success-emoji { font-size: 3.5rem; margin-bottom: 1rem; display: block; }
    .success-title { font-family: var(--font-display); font-size: 1.8rem; font-weight: 900; color: var(--text-dark); margin-bottom: 0.7rem; }
    .success-msg { font-size: 0.9rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 2rem; }
    .btn-close-success { padding: 0.85rem 2.5rem; background: var(--forest-btn); color: white; border: none; border-radius: 10px; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; transition: background .2s; }
    .btn-close-success:hover { background: var(--forest); }

    /* ERRORS */
    .q-card.has-error { border-color: #c0392b !important; box-shadow: 0 0 0 3px rgba(192,57,43,0.1) !important; animation: shake .35s cubic-bezier(.36,.07,.19,.97); }
    @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-5px)} 40%{transform:translateX(5px)} 60%{transform:translateX(-3px)} 80%{transform:translateX(3px)} }
    .q-error { margin-top: 0.75rem; padding: 0.5rem 0.8rem; background: rgba(192,57,43,0.07); border-radius: 8px; font-size: 0.78rem; color: #c0392b; font-weight: 500; border-left: 3px solid #c0392b; }

    /* FADE */
    .fade-up { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    
    @media (max-width: 600px) {
      .form-hero { padding: 3rem 1.5rem 4rem; }
      .form-body { padding: 2rem 1rem 5rem; }
      .navbar { padding: 0 1.2rem; }
      .q-card { padding: 1.3rem 1.2rem; }
      .options-list.inline { flex-direction: column; }
    }



  </style>


  <nav class="navbar">
     <a href="/" class="nav-back">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>
      Torna alla home
    </a>
    <a href="/" class="nav-logo">Zeno</a>
   
  </nav>
  <header class="form-hero">
  <div class="form-eyebrow">Questionario Utenti</div>
  <h1 class="form-hero-title">Aiutaci a capire <br> di cosa hai bisogno</h1>
  <p class="form-hero-sub">Le Tue abitudini alimentari ci aiutano a costruire un servizio<br><strong>che si adatti davvero alla tua vita.</strong></p>
  <div class="form-hero-meta">
    
        <span class="meta-pill">
  <svg  viewBox="0 0 150 152">
<path d="M45.4958 145.695C36.4215 141.714 28.5281 136.31 21.8156 129.485C15.1031 122.66 9.78906 114.635 5.87344 105.408C1.95781 96.182 0 86.3236 0 75.8333C0 65.3431 1.95781 55.4847 5.87344 46.2583C9.78906 37.0319 15.1031 29.0063 21.8156 22.1813C28.5281 15.3563 36.4215 9.95313 45.4958 5.97188C54.5701 1.99063 64.266 0 74.5833 0C84.9007 0 94.5965 1.99063 103.671 5.97188C112.745 9.95313 120.639 15.3563 127.351 22.1813C134.064 29.0063 139.378 37.0319 143.293 46.2583C147.209 55.4847 149.167 65.3431 149.167 75.8333C149.167 86.3236 147.209 96.182 143.293 105.408C139.378 114.635 134.064 122.66 127.351 129.485C120.639 136.31 112.745 141.714 103.671 145.695C94.5965 149.676 84.9007 151.667 74.5833 151.667C64.266 151.667 54.5701 149.676 45.4958 145.695ZM116.909 118.869C128.47 107.115 134.25 92.7695 134.25 75.8333C134.25 67.7444 132.758 59.9715 129.775 52.5146C126.792 45.0576 122.503 38.4854 116.909 32.7979L74.5833 75.8333V15.1667C57.9264 15.1667 43.8177 21.0438 32.2573 32.7979C20.6969 44.5521 14.9167 58.8972 14.9167 75.8333C14.9167 92.7695 20.6969 107.115 32.2573 118.869C43.8177 130.623 57.9264 136.5 74.5833 136.5C91.2403 136.5 105.349 130.623 116.909 118.869Z" fill="white"/>
</svg>

      ~5 minuti
    </span>
    
   <span class="meta-pill">
    <svg viewBox="0 0 166 218">
    <path d="M20.75 217.875C15.0438 217.875 10.1589 215.843 6.09531 211.78C2.03177 207.716 0 202.831 0 197.125V93.375C0 87.6688 2.03177 82.7839 6.09531 78.7203C10.1589 74.6568 15.0438 72.625 20.75 72.625H31.125V51.875C31.125 37.5229 36.1828 25.2891 46.2984 15.1734C56.4141 5.05781 68.6479 0 83 0C97.3521 0 109.586 5.05781 119.702 15.1734C129.817 25.2891 134.875 37.5229 134.875 51.875V72.625H145.25C150.956 72.625 155.841 74.6568 159.905 78.7203C163.968 82.7839 166 87.6688 166 93.375V197.125C166 202.831 163.968 207.716 159.905 211.78C155.841 215.843 150.956 217.875 145.25 217.875H20.75ZM20.75 197.125H145.25V93.375H20.75V197.125ZM97.6547 159.905C101.718 155.841 103.75 150.956 103.75 145.25C103.75 139.544 101.718 134.659 97.6547 130.595C93.5911 126.532 88.7063 124.5 83 124.5C77.2938 124.5 72.4089 126.532 68.3453 130.595C64.2818 134.659 62.25 139.544 62.25 145.25C62.25 150.956 64.2818 155.841 68.3453 159.905C72.4089 163.968 77.2938 166 83 166C88.7063 166 93.5911 163.968 97.6547 159.905ZM51.875 72.625H114.125V51.875C114.125 43.2292 111.099 35.8802 105.047 29.8281C98.9948 23.776 91.6458 20.75 83 20.75C74.3542 20.75 67.0052 23.776 60.9531 29.8281C54.901 35.8802 51.875 43.2292 51.875 51.875V72.625Z" fill="white"/>
    </svg>
Dati anonimi
    </span>
    
    <span class="meta-pill">
    <svg viewBox="0 0 64 48">
      <path d="M22.325 47.0979L0 24.7729L5.58125 19.1917L22.325 35.9354L58.2604 0L63.8417 5.58125L22.325 47.0979Z" fill="white"/>
    </svg>

      Risposte opzionali
    </span>
  </div>
</header>

  <div class="progress-wrap">
    <div class="progress-inner">
      <span class="progress-label">Completamento</span>
      <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
      <span class="progress-pct" id="progressPct">0%</span>
    </div>
  </div>

  <main class="form-body">
    <form id="zenoForm" novalidate>

      <!-- ── SEZIONE 1: Profilo ── -->
      <div class="form-section fade-up">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
          <span class="section-title">Il tuo profilo</span>
        </div>
        <div class="section-divider"></div>

        <div class="q-card">
          <label class="q-label" for="field-age">Quanti anni hai?</label>
          <input type="number" class="q-input" id="field-age" name="entry.AGE" placeholder="es. 28" min="13" max="110" aria-required="true" />
        </div>

        <div class="q-card">
          <label class="q-label" for="field-city">Dove vivi? <span style="font-weight:400; color:var(--text-muted); font-size:0.82em">(città / quartiere)</span></label>
          <input type="text" class="q-input" id="field-city" name="entry.CITY" placeholder="es. Milano, Isola" aria-required="true" />
        </div>

        <div class="q-card">
          <div class="q-label">Qual è la tua situazione abitativa?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.LIVING" value="Da solo" /><span class="opt-text">Da solo</span></label>
            <label class="opt"><input type="radio" name="entry.LIVING" value="Con coinquilini" /><span class="opt-text">Con coinquilini</span></label>
            <label class="opt"><input type="radio" name="entry.LIVING" value="In coppia" /><span class="opt-text">In coppia</span></label>
            <label class="opt"><input type="radio" name="entry.LIVING" value="In famiglia" /><span class="opt-text">In famiglia</span></label>
          </div>
        </div>

        <div class="q-card">
          <label class="q-label" for="field-job">Qual è la tua occupazione?</label>
          <input type="text" class="q-input" id="field-job" name="entry.JOB" placeholder="es. Studente, Designer, Insegnante…" aria-required="true" />
        </div>
      </div>

      <!-- ── SEZIONE 2: Alimentazione ── -->
      <div class="form-section fade-up" style="transition-delay:.05s">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <span class="section-title">Abitudini alimentari e dieta</span>
        </div>
        <div class="section-divider"></div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Segui un tipo di dieta particolare?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.DIET" value="Onnivora" /><span class="opt-text">Onnivora</span></label>
            <label class="opt"><input type="radio" name="entry.DIET" value="Flexitariana (mangio carne/pesce solo occasionalmente)" /><span class="opt-text">Flexitariana <span style="color:var(--text-muted);font-size:.82em">(mangio carne/pesce solo occasionalmente)</span></span></label>
            <label class="opt"><input type="radio" name="entry.DIET" value="Vegetariana" /><span class="opt-text">Vegetariana</span></label>
            <label class="opt"><input type="radio" name="entry.DIET" value="Vegana" /><span class="opt-text">Vegana</span></label>
          </div>
        </div>

        <!-- CHECKBOX: più scelte, max 2 -->
        <div class="q-card">
          <div class="q-label">Quali sono per te le priorità nella spesa alimentare?</div>
          <div class="q-hint" id="priorityHint">Scegli al massimo 2 opzioni</div>
          <div class="options-list" id="priorityList">
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Prezzo" /><span class="opt-text">Prezzo</span></label>
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Provenienza locale" /><span class="opt-text">Provenienza locale</span></label>
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Etica e benessere animale" /><span class="opt-text">Etica e benessere animale</span></label>
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Impatto ambientale" /><span class="opt-text">Impatto ambientale</span></label>
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Convenienza (tempo/ritiro)" /><span class="opt-text">Convenienza <span style="color:var(--text-muted);font-size:.82em">(tempo / ritiro)</span></span></label>
            <label class="opt"><input type="checkbox" name="entry.PRIORITY" value="Gusto e qualità" /><span class="opt-text">Gusto e qualità</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta (opzionale) -->
        <div class="q-card">
          <div class="q-label">Se sei vegetariano/a o vegano/a, quali sono state le principali motivazioni?</div>
          <div class="q-hint">Lascia in bianco se non applicabile</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.VEG_MOTIV" value="Benessere personale / salute" /><span class="opt-text">Benessere personale / salute</span></label>
            <label class="opt"><input type="radio" name="entry.VEG_MOTIV" value="Ragioni etiche (benessere animale)" /><span class="opt-text">Ragioni etiche <span style="color:var(--text-muted);font-size:.82em">(benessere animale)</span></span></label>
            <label class="opt"><input type="radio" name="entry.VEG_MOTIV" value="Ragioni ambientali (impatto ecologico)" /><span class="opt-text">Ragioni ambientali <span style="color:var(--text-muted);font-size:.82em">(impatto ecologico)</span></span></label>
            <label class="opt"><input type="radio" name="entry.VEG_MOTIV" value="Motivi religiosi/culturali" /><span class="opt-text">Motivi religiosi / culturali</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Se sei onnivoro/a, hai mai pensato di ridurre il consumo di carne o derivati animali?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.MEAT_REDUCE" value="No, non ci penso" /><span class="opt-text">No, non ci penso</span></label>
            <label class="opt"><input type="radio" name="entry.MEAT_REDUCE" value="Sì, ma non so come fare" /><span class="opt-text">Sì, ma non so come fare</span></label>
            <label class="opt"><input type="radio" name="entry.MEAT_REDUCE" value="Sì, già sto riducendo" /><span class="opt-text">Sì, già sto riducendo</span></label>
            <label class="opt"><input type="radio" name="entry.MEAT_REDUCE" value="Sì, e vorrei ridurre ancora di più" /><span class="opt-text">Sì, e vorrei ridurre ancora di più</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Quanto è importante per te la provenienza della carne/pesce che consumi?</div>
          <div class="q-hint">es. allevamenti non intensivi, pesca sostenibile</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.ORIGIN_IMP" value="Per nulla importante" /><span class="opt-text">Per nulla importante</span></label>
            <label class="opt"><input type="radio" name="entry.ORIGIN_IMP" value="Poco importante" /><span class="opt-text">Poco importante</span></label>
            <label class="opt"><input type="radio" name="entry.ORIGIN_IMP" value="Abbastanza importante" /><span class="opt-text">Abbastanza importante</span></label>
            <label class="opt"><input type="radio" name="entry.ORIGIN_IMP" value="Molto importante" /><span class="opt-text">Molto importante</span></label>
          </div>
        </div>
      </div>

      <!-- ── SEZIONE 3: Abitudini di spesa ── -->
      <div class="form-section fade-up" style="transition-delay:.1s">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6"/></svg></div>
          <span class="section-title">Abitudini di spesa attuali</span>
        </div>
        <div class="section-divider"></div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Dove fai principalmente la spesa alimentare?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.SHOP_WHERE" value="Supermercato tradizionale" /><span class="opt-text">Supermercato tradizionale</span></label>
            <label class="opt"><input type="radio" name="entry.SHOP_WHERE" value="Supermercato bio" /><span class="opt-text">Supermercato bio</span></label>
            <label class="opt"><input type="radio" name="entry.SHOP_WHERE" value="Mercato" /><span class="opt-text">Mercato</span></label>
            <label class="opt"><input type="radio" name="entry.SHOP_WHERE" value="GAS / produttori locali" /><span class="opt-text">GAS / produttori locali</span></label>
            <label class="opt"><input type="radio" name="entry.SHOP_WHERE" value="Altre piattaforme online" /><span class="opt-text">Altre piattaforme online</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Quanto spendi mediamente al mese per la spesa alimentare?</div>
          <div class="options-list inline">
            <label class="opt"><input type="radio" name="entry.MONTHLY_SPEND" value="Meno di 200 €" /><span class="opt-text">Meno di 200 €</span></label>
            <label class="opt"><input type="radio" name="entry.MONTHLY_SPEND" value="200 – 400 €" /><span class="opt-text">200 – 400 €</span></label>
            <label class="opt"><input type="radio" name="entry.MONTHLY_SPEND" value="400 – 600 €" /><span class="opt-text">400 – 600 €</span></label>
            <label class="opt"><input type="radio" name="entry.MONTHLY_SPEND" value="Più di 600 €" /><span class="opt-text">Più di 600 €</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Quanto spendi in media per prodotti bio / etici / locali?</div>
          <div class="options-list inline">
            <label class="opt"><input type="radio" name="entry.BIO_SPEND" value="Nulla / quasi nulla" /><span class="opt-text">Nulla / quasi nulla</span></label>
            <label class="opt"><input type="radio" name="entry.BIO_SPEND" value="Fino a 20% della spesa" /><span class="opt-text">Fino al 20%</span></label>
            <label class="opt"><input type="radio" name="entry.BIO_SPEND" value="20–50% della spesa" /><span class="opt-text">20–50%</span></label>
            <label class="opt"><input type="radio" name="entry.BIO_SPEND" value="Oltre 50% della spesa" /><span class="opt-text">Oltre 50%</span></label>
          </div>
        </div>
      </div>

      <!-- ── SEZIONE 4: GAS ── -->
      <div class="form-section fade-up" style="transition-delay:.15s">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <span class="section-title">Conoscenza e interesse verso i GAS</span>
        </div>
        <div class="section-divider"></div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Conosci già i GAS (Gruppi di Acquisto Solidale)?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.GAS_KNOW" value="No, mai sentito" /><span class="opt-text">No, mai sentito</span></label>
            <label class="opt"><input type="radio" name="entry.GAS_KNOW" value="Sì, ma non ne faccio parte" /><span class="opt-text">Sì, ma non ne faccio parte</span></label>
            <label class="opt"><input type="radio" name="entry.GAS_KNOW" value="Sì, e ne faccio parte/ho partecipato" /><span class="opt-text">Sì, e ne faccio parte / ho partecipato</span></label>
          </div>
        </div>
      </div>

      <!-- ── SEZIONE 5: Propensione al cambiamento ── -->
      <div class="form-section fade-up" style="transition-delay:.2s">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg></div>
          <span class="section-title">Propensione al cambiamento</span>
        </div>
        <div class="section-divider"></div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Saresti disposto/a a cambiare parte delle tue abitudini di spesa per sostenere un modello più etico e sostenibile?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.CHANGE_WILL" value="No" /><span class="opt-text">No</span></label>
            <label class="opt"><input type="radio" name="entry.CHANGE_WILL" value="Forse, se non costa di più" /><span class="opt-text">Forse, se non costa di più</span></label>
            <label class="opt"><input type="radio" name="entry.CHANGE_WILL" value="Sì, se costa uguale o leggermente di più" /><span class="opt-text">Sì, se costa uguale o leggermente di più</span></label>
            <label class="opt"><input type="radio" name="entry.CHANGE_WILL" value="Sì, anche spendendo un po' di più" /><span class="opt-text">Sì, anche spendendo un po' di più</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Quanto in più saresti disposto/a a pagare per prodotti etici / trasparenti rispetto al supermercato?</div>
          <div class="options-list inline">
            <label class="opt"><input type="radio" name="entry.PRICE_EXTRA" value="Niente" /><span class="opt-text">Niente</span></label>
            <label class="opt"><input type="radio" name="entry.PRICE_EXTRA" value="Fino al +10%" /><span class="opt-text">Fino al +10%</span></label>
            <label class="opt"><input type="radio" name="entry.PRICE_EXTRA" value="Fino al +20%" /><span class="opt-text">Fino al +20%</span></label>
            <label class="opt"><input type="radio" name="entry.PRICE_EXTRA" value="Oltre il +20%" /><span class="opt-text">Oltre il +20%</span></label>
          </div>
        </div>
      </div>

      <!-- ── SEZIONE 6: Piattaforma digitale ── -->
      <div class="form-section fade-up" style="transition-delay:.25s">
        <div class="section-label">
          <div class="section-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <span class="section-title">Interesse verso una piattaforma digitale</span>
        </div>
        <div class="section-divider"></div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Se esistesse un'app che ti permette di unirti facilmente a un GAS, ordinare online, pagare con carta e scegliere orari/luoghi di ritiro… ti interesserebbe provarla?</div>
          <div class="options-list inline">
            <label class="opt"><input type="radio" name="entry.APP_INTEREST" value="Sì" /><span class="opt-text">Sì</span></label>
            <label class="opt"><input type="radio" name="entry.APP_INTEREST" value="No" /><span class="opt-text">No</span></label>
            <label class="opt"><input type="radio" name="entry.APP_INTEREST" value="Forse" /><span class="opt-text">Forse</span></label>
          </div>
        </div>

        <!-- RADIO: una sola scelta -->
        <div class="q-card">
          <div class="q-label">Saresti disposto a pagare una piccola commissione (1–2 € a spesa) per accedere a questo servizio?</div>
          <div class="options-list">
            <label class="opt"><input type="radio" name="entry.COMMISSION" value="Sì" /><span class="opt-text">Sì</span></label>
            <label class="opt"><input type="radio" name="entry.COMMISSION" value="No" /><span class="opt-text">No</span></label>
            <label class="opt"><input type="radio" name="entry.COMMISSION" value="Se il risparmio complessivo lo giustifica" /><span class="opt-text">Se il risparmio complessivo lo giustifica</span></label>
          </div>
        </div>

        <!-- TESTO LIBERO -->
        <div class="q-card">
          <label class="q-label" for="field-app-value">Quale sarebbe per te il principale valore aggiunto di una piattaforma così?</label>
          <textarea class="q-textarea" id="field-app-value" name="entry.APP_VALUE" placeholder="Scrivi qui la tua risposta…"></textarea>
        </div>

        <!-- EMAIL opzionale -->
        <div class="q-card">
          <label class="q-label" for="field-email">Lasceresti la tua email per essere ricontattato/a e provare il servizio in anteprima?</label>
          <div class="q-hint">Opzionale — usata solo per avvisarti del lancio</div>
          <input type="email" class="q-input" id="field-email" name="entry.EMAIL" placeholder="tua@email.com" />
        </div>
      </div>

      <!-- SUBMIT -->
      <div class="submit-section fade-up" style="transition-delay:.3s">
        <div class="submit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div class="submit-title">Quasi fatto!</div>
        <p class="submit-sub">Le tue risposte ci aiutano a costruire qualcosa di davvero utile. Grazie per il tuo tempo.</p>
        <button type="submit" class="btn-submit" id="submitBtn">Invia il questionario</button>
      </div>

    </form>
  </main>

  <div class="success-overlay" id="successOverlay">
    <div class="success-card">
      <span class="success-emoji">🌿</span>
      <div class="success-title">Grazie mille!</div>
      <p class="success-msg">Le tue risposte sono state inviate con successo. Aiuteranno Zeno a costruire un servizio che funzioni davvero per te e per la tua comunità.</p>
      <a href="/" class="btn-close-success">Torna alla home</a>
    </div>
  </div>

  <script>
    const form = document.getElementById('zenoForm');

    // ── FIELD NAMES for progress tracking ──
    const FIELD_NAMES = [
      'entry.AGE','entry.CITY','entry.LIVING','entry.JOB',
      'entry.DIET','entry.PRIORITY','entry.VEG_MOTIV','entry.MEAT_REDUCE',
      'entry.ORIGIN_IMP','entry.SHOP_WHERE','entry.MONTHLY_SPEND','entry.BIO_SPEND',
      'entry.GAS_KNOW','entry.CHANGE_WILL','entry.PRICE_EXTRA',
      'entry.APP_INTEREST','entry.COMMISSION','entry.APP_VALUE','entry.EMAIL'
    ];
    function updateProgress() {
      const answered = new Set();
      form.querySelectorAll('input[type=radio]:checked, input[type=checkbox]:checked')
          .forEach(i => answered.add(i.name));
      form.querySelectorAll('input[type=text], input[type=email], input[type=number], textarea')
          .forEach(i => { if (i.name && i.value.trim()) answered.add(i.name); });
      const pct = Math.round((answered.size / FIELD_NAMES.length) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressPct').textContent  = pct + '%';
    }
    form.addEventListener('change', updateProgress);
    form.addEventListener('input',  updateProgress);

    // ── MAX 2 per priorità ──
    document.getElementById('priorityList').addEventListener('change', () => {
      const checked = document.querySelectorAll('#priorityList input:checked');
      if (checked.length > 2) {
        checked[checked.length - 1].checked = false;
        const hint = document.getElementById('priorityHint');
        hint.style.color = '#c0392b'; hint.style.fontWeight = '600';
        hint.textContent = '⚠ Puoi scegliere al massimo 2 opzioni';
        setTimeout(() => {
          hint.style.color = ''; hint.style.fontWeight = '';
          hint.textContent = 'Scegli al massimo 2 opzioni';
        }, 2200);
      }
    });

    // ── VALIDAZIONE ──
    function getCard(name) {
      const el = form.querySelector(`[name="${name}"]`);
      return el ? el.closest('.q-card') : null;
    }
    function showError(card, msg) {
      card.classList.add('has-error');
      if (!card.querySelector('.q-error')) {
        const d = document.createElement('div');
        d.className = 'q-error'; d.setAttribute('role', 'alert'); d.textContent = '⚠ ' + msg;
        card.appendChild(d);
      }
    }
    function clearErrors() {
      form.querySelectorAll('.has-error').forEach(c => {
        c.classList.remove('has-error');
        c.querySelectorAll('.q-error').forEach(e => e.remove());
      });
    }
    form.addEventListener('change', e => {
      const c = e.target.closest('.q-card');
      if (c) { c.classList.remove('has-error'); c.querySelectorAll('.q-error').forEach(e => e.remove()); }
    });

    const REQUIRED = ['entry.AGE','entry.CITY','entry.LIVING','entry.JOB','entry.DIET',
      'entry.PRIORITY','entry.SHOP_WHERE','entry.MONTHLY_SPEND','entry.BIO_SPEND',
      'entry.GAS_KNOW','entry.CHANGE_WILL','entry.PRICE_EXTRA','entry.APP_INTEREST','entry.COMMISSION'];

    function validate() {
      clearErrors();
      let firstErr = null;
      let ok = true;
      for (const name of REQUIRED) {
        const card = getCard(name);
        if (!card) continue;
        const inputs = form.querySelectorAll(`[name="${name}"]`);
        const type   = inputs[0]?.type;
        let answered = false;
        if (type === 'radio' || type === 'checkbox') {
          answered = !!form.querySelector(`[name="${name}"]:checked`);
        } else if (type === 'number') {
          const v = parseInt(inputs[0].value);
          answered = !isNaN(v) && v >= 13 && v <= 110;
          if (inputs[0].value && !answered) { showError(card, "Inserisci un'età valida (13–110)."); if (!firstErr) firstErr = card; ok = false; continue; }
        } else {
          answered = inputs[0]?.value.trim().length >= 2;
        }
        if (!answered) {
          showError(card, type === 'radio' || type === 'checkbox' ? "Seleziona un'opzione." : 'Campo obbligatorio (min. 2 caratteri).');
          if (!firstErr) firstErr = card;
          ok = false;
        }
      }
      // email format
      const emailEl = form.querySelector('[name="entry.EMAIL"]');
      if (emailEl?.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
        const c = emailEl.closest('.q-card');
        showError(c, 'Inserisci un indirizzo email valido.');
        if (!firstErr) firstErr = c;
        ok = false;
      }
      if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return ok;
    }

    // ── LABEL MAP (nomi campo → domanda leggibile) ──
    const LABELS = {
      'entry.AGE': 'Quanti anni hai',
      'entry.CITY': 'Dove vivi',
      'entry.LIVING': 'Situazione abitativa',
      'entry.JOB': 'Occupazione',
      'entry.DIET': 'Tipo di dieta',
      'entry.PRIORITY': 'Priorità nella spesa alimentare',
      'entry.VEG_MOTIV': 'Motivazioni vegetariano/vegano',
      'entry.MEAT_REDUCE': 'Riduzione consumo carne',
      'entry.ORIGIN_IMP': 'Importanza provenienza carne/pesce',
      'entry.SHOP_WHERE': 'Dove fai la spesa',
      'entry.MONTHLY_SPEND': 'Spesa mensile alimentare',
      'entry.BIO_SPEND': 'Spesa prodotti bio/etici/locali',
      'entry.GAS_KNOW': 'Conoscenza GAS',
      'entry.CHANGE_WILL': 'Disponibilità al cambiamento',
      'entry.PRICE_EXTRA': 'Quanto in più per prodotti etici',
      'entry.APP_INTEREST': 'Interesse per app GAS',
      'entry.COMMISSION': 'Disponibilità a commissione',
      'entry.APP_VALUE': 'Valore aggiunto piattaforma',
      'entry.EMAIL': 'Email',
    };

    // ── SUBMIT VIA RESEND API ──
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) return;

      const btn = document.getElementById('submitBtn');
      btn.disabled    = true;
      btn.textContent = 'Invio in corso…';

      const rawData = new FormData(form);
      const fields = [];
      const seen = new Set();
      for (const [key] of rawData.entries()) {
        if (seen.has(key)) continue;
        seen.add(key);
        const values = rawData.getAll(key).filter(v => v.trim());
        if (values.length === 0) continue;
        const label = LABELS[key] || key;
        fields.push({ label, value: values.join(', ') });
      }

      try {
        const res = await fetch('/api/submit-form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'utenti', fields }),
        });

        const emailVal = form.querySelector('[name="entry.EMAIL"]')?.value?.trim();
        if (emailVal) {
          const emailData = new FormData();
          emailData.append('email', emailVal);
          fetch('https://formspree.io/f/maqlddnl', {
            method: 'POST',
            body: emailData,
            headers: { 'Accept': 'application/json' },
          }).catch(() => {});
        }

        if (res.ok) {
          document.getElementById('successOverlay').classList.add('show');
        } else {
          alert('Errore nell\'invio. Riprova tra qualche istante.');
        }
      } catch (err) {
        console.error('Errore di invio:', err);
        alert('Errore di rete. Controlla la connessione e riprova.');
      } finally {
        btn.disabled    = false;
        btn.textContent = 'Invia il questionario';
      }
    });

    // ── FADE UP ──
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
  </script>


</BaseLayout>